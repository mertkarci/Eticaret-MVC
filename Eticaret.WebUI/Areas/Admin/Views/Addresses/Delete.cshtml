@model Eticaret.Core.Entities.Address

@{
    ViewData["Title"] = "Adresi Sil";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-admin border-danger shadow">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i> Silme İşlemini Onayla</h4>
            </div>
            <div class="card-body p-4">
                <p class="fs-5">
                    Aşağıdaki adresi kalıcı olarak silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.
                </p>
                <hr>
                <dl class="row">
                    <dt class="col-sm-4 text-muted">Adres Başlığı</dt>
                    <dd class="col-sm-8 fw-bold">@Model.Title</dd>
                    <dt class="col-sm-4 text-muted">Kullanıcı</dt>
                    <dd class="col-sm-8">@Model.AppUser?.Name @Model.AppUser?.Surname</dd>
                </dl>
                <hr>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg me-2"></i> İptal</a>
                        <button type="submit" class="btn btn-danger"><i class="bi bi-trash-fill me-2"></i> Evet, Sil</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>