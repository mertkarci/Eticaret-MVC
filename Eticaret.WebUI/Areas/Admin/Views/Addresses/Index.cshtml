@model IEnumerable<Eticaret.Core.Entities.Address>

@{
    ViewData["Title"] = "Adres Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Create" class="btn btn-create shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Yeni Adres Ekle
    </a>
</div>

<div class="card card-admin">
    <div class="card-body">
        <table id="datatablesSimple" class="table-admin table-hover">
            <thead>
                <tr>
                    <th class="ps-4">@Html.DisplayNameFor(model => model.Title)</th>
                    <th>@Html.DisplayNameFor(model => model.City)</th>
                    <th>@Html.DisplayNameFor(model => model.District)</th>
                    <th>@Html.DisplayNameFor(model => model.OpenAddress)</th>
                    <th>@Html.DisplayNameFor(model => model.IsActive)</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-dark">@Html.DisplayFor(modelItem => item.Title)</td>
                        <td>@Html.DisplayFor(modelItem => item.City)</td>
                        <td>@Html.DisplayFor(modelItem => item.District)</td>
                        <td class="text-truncate" style="max-width: 200px;">@Html.DisplayFor(modelItem => item.OpenAddress)</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success rounded-pill px-3 py-2">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-50 rounded-pill px-3 py-2">Pasif</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="action-buttons">
                                <a asp-action="Edit" class="btn btn-outline-primary" asp-route-id="@item.Id" title="Düzenle">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="Delete" class="btn btn-outline-danger" asp-route-id="@item.Id" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>