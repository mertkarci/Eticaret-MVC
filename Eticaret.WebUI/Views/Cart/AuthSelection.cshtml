<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="fw-bold mb-4">Devam Etmek İçin Seçim Yapın</h2>
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card p-4 border-0 shadow-sm rounded-4 h-100">
                        <i class="bi bi-person-circle display-4 text-primary mb-3"></i>
                        <h5>Üye Girişi</h5>
                        <p class="small text-muted mb-4">Kayıtlı adreslerinizle hızlıca devam edin.</p>
                        <a asp-controller="Accounts" asp-action="SignIn" asp-route-ReturnUrl="/sepetim/ödeme" class="btn btn-primary rounded-pill w-100">Giriş Yap</a>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card p-4 border-0 shadow-sm rounded-4 h-100 bg-light">
                        <i class="bi bi-person-dash display-4 text-secondary mb-3"></i>
                        <h5>Misafir Olarak</h5>
                        <p class="small text-muted mb-4">Üye olmadan sadece iletişim bilgileriyle devam edin.</p>
                        <a asp-action="Checkout" asp-route-isGuest="true" class="btn btn-dark rounded-pill w-100">Misafir Devam Et</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>