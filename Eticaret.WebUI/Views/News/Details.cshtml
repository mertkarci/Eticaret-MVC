@model News
@{
    ViewData["Title"] = Model.Name;
}

<section class="py-5" style="background-color: #f4f6f9;">
    <div class="container">

        @* --- BREADCRUMB DİNAMİKLEŞTİRİLDİ --- *@
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb bg-transparent p-0 m-0 justify-content-center">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted small">
                        <i class="bi bi-house-door"></i> Ana Sayfa
                    </a>
                </li>
                <li class="breadcrumb-item">
                    @* Controller'daki [Route("kampanyalar")] burayı otomatik /kampanyalar yapar *@
                    <a asp-controller="News" asp-action="Index" class="text-decoration-none text-muted small">Haberler</a>
                </li>
                <li class="breadcrumb-item active text-dark small fw-bold" aria-current="page">@Model.Name</li>
            </ol>
        </nav>

        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-8">

                <article class="news-paper shadow-lg">
                    <header class="text-center mb-4">
                        @* Başlığı buraya da alabiliriz, header boş kalmasın *@
                        <h1 class="article-title fw-bold text-dark mb-0">@Model.Name</h1>
                    </header>

                    <div class="photo-frame mb-5">
                        @* Resim yolu dinamikleştirildi *@
                        <img src="~/img/news/@Model.Image" alt="@Model.Name" class="img-fluid w-100 object-fit-cover" asp-append-version="true">
                    </div>

                    <div class="content-surface shadow-sm">
                        <div class="article-content text-secondary">
                            @* Eğer içerik HTML etiketleri içeriyorsa Html.Raw kullanmalısın *@
                            @Html.Raw(Model.Description)
                        </div>
                    </div>

                    <hr class="my-5 border-secondary opacity-10">

                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-3">
                        @* --- GERİ DÖN BUTONU DİNAMİKLEŞTİRİLDİ --- *@
                        <a asp-controller="News" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4 w-100 w-sm-auto">
                            <i class="bi bi-arrow-left me-2"></i> Haberlere Dön
                        </a>

                        <div class="d-flex justify-content-center align-items-center text-muted small">
                            <div class="d-flex align-items-center me-4">
                                <i class="bi bi-calendar-event me-2 text-primary"></i>
                                <span>@Model.CreateDate.ToString("dd MMMM yyyy")</span>
                            </div>
                        </div>
                    </div>
                </article>

            </div>
        </div>
    </div>
</section>