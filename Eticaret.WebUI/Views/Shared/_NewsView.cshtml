@model Eticaret.Core.Entities.News

<div class="col mb-4">
    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden news-card-hover">
        <a asp-controller="News" asp-action="Details" asp-route-id="@Model.Id" class="...">
            <div class="position-relative overflow-hidden" style="height: 240px;">
                @if (!string.IsNullOrEmpty(Model.Image))
                {
                    <img src="/img/news/@Model.Image" class="w-100 h-100 object-fit-cover transition-scale"
                        alt="@Model.Name">
                }
                else
                {
                    <div class="w-100 h-100 bg-light d-flex align-items-center justify-content-center">
                        <i class="bi bi-image text-muted fs-1"></i>
                    </div>
                }

                <div class="position-absolute top-0 end-0 m-3">
                    <span class="badge bg-white text-dark shadow-sm rounded-pill px-3 py-2">
                        <i class="bi bi-calendar-event me-1 text-primary"></i> @Model.CreateDate.ToString("dd MMM")
                    </span>
                </div>
            </div>
        </a>


        <div class="card-body p-4 d-flex flex-column">
            <h5 class="fw-bold mb-3 text-truncate">@Model.Name</h5>

            <p class="text-secondary small mb-4 flex-grow-1"
                style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.6;">
                @Model.Description
            </p>

            <div class="d-flex align-items-center justify-content-between pt-3 border-top border-light mt-auto">
                <span class="text-primary fw-bold small">Devamını Oku</span>
                <i class="bi bi-arrow-right text-primary"></i>
            </div>
        </div>
        </a>
    </div>
</div>

<style>
    .news-card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background-color: #fff;
    }

    .news-card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1) !important;
    }

    .news-card-hover:hover .transition-scale {
        transform: scale(1.05);
    }

    .transition-scale {
        transition: transform 0.5s ease;
    }

    .object-fit-cover {
        object-fit: cover;
    }
</style>