@model Eticaret.Core.Entities.Order

@{
    ViewData["Title"] = "Sipariş Detayları";
}

<div class="row g-4">
    <div class="col-lg-8">
        <!-- Sipariş Ürünleri -->
        <div class="card card-admin mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Sipariş İçeriği</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Ürün</th>
                                <th class="text-center">Adet</th>
                                <th class="text-end pe-4">Birim Fiyat</th>
                                <th class="text-end pe-4">Toplam</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.OrderLines != null)
                            {
                                @foreach (var item in Model.OrderLines)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <span class="fw-medium">@item.Product?.Name</span>
                                        </td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end pe-4">@item.UnitPrice.ToString("c")</td>
                                        <td class="text-end pe-4 fw-bold">@((item.Quantity * item.UnitPrice).ToString("c"))</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot class="bg-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold py-3">Genel Toplam:</td>
                                <td class="text-end pe-4 fw-bold text-success fs-5 py-3">@Model.TotalPrice.ToString("c")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="sticky-form-sidebar">
            <!-- Sipariş Bilgileri -->
            <div class="card card-admin mb-4">
                <div class="card-header"><h5 class="card-title mb-0">Sipariş Özeti</h5></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5 text-muted">Sipariş No</dt>
                        <dd class="col-sm-7 fw-bold">#@Model.OrderNumber</dd>

                        <dt class="col-sm-5 text-muted">Tarih</dt>
                        <dd class="col-sm-7">@Model.OrderDate.ToString("dd.MM.yyyy HH:mm")</dd>

                        <dt class="col-sm-5 text-muted">Müşteri</dt>
                        <dd class="col-sm-7">@Model.AppUser?.Name @Model.AppUser?.Surname</dd>
                        
                        <dt class="col-sm-5 text-muted">Durum</dt>
                        <dd class="col-sm-7">
                            <span class="badge bg-primary">@Model.OrderState</span>
                        </dd>
                    </dl>
                </div>
            </div>

            <!-- Adres Bilgileri (Opsiyonel, modelde varsa eklenebilir) -->
            @if (!string.IsNullOrEmpty(Model.DeliveryAddress))
            {
                <div class="card card-admin mb-4">
                    <div class="card-header"><h5 class="card-title mb-0">Teslimat Adresi</h5></div>
                    <div class="card-body small">
                        @Model.DeliveryAddress
                    </div>
                </div>
            }

            <!-- İşlemler -->
            <div class="card card-admin">
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary shadow-sm"><i class="bi bi-pencil-square me-2"></i> Siparişi Düzenle</a>
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i> Listeye Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>