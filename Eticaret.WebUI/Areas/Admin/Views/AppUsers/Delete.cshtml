@model Eticaret.Core.Entities.AppUser

@{
    ViewData["Title"] = "Kullanıcıyı Sil";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-admin border-danger shadow">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i> Silme İşlemini Onayla</h4>
            </div>
            <div class="card-body p-4">
                <p class="fs-5">
                    Aşağıdaki kullanıcıyı silmek istediğinizden emin misiniz?
                </p>
                <hr>
                <dl class="row">
                    <dt class="col-sm-3 text-muted">Ad Soyad</dt>
                    <dd class="col-sm-9 fw-bold">@Model.Name @Model.Surname</dd>

                    <dt class="col-sm-3 text-muted">E-Posta</dt>
                    <dd class="col-sm-9">@Model.Email</dd>
                </dl>
                <hr>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />

                    <div class="alert alert-warning d-flex align-items-center" role="alert">
                        <i class="bi bi-shield-fill-exclamation fs-4 me-3"></i>
                        <div>
                            Varsayılan olarak kullanıcılar pasife alınır (Soft Delete). Bu, kullanıcının sipariş ve adres geçmişinin korunmasını sağlar.
                            Kullanıcıyı ve tüm ilişkili verilerini (adresler, siparişler vb.) <strong>kalıcı olarak</strong> silmek için aşağıdaki kutucuğu işaretleyin.
                        </div>
                    </div>

                    <div class="form-check form-switch my-4">
                        <input class="form-check-input" type="checkbox" name="isHardDelete" value="true" id="hardDeleteSwitch">
                        <label class="form-check-label fw-bold text-danger" for="hardDeleteSwitch">
                            Kalıcı Olarak Sil (Hard Delete)
                        </label>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg me-2"></i> İptal</a>
                        <button type="submit" class="btn btn-danger"><i class="bi bi-trash-fill me-2"></i> Evet, Silme İşlemini Onayla</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>