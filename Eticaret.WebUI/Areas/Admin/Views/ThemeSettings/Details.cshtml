@model Eticaret.Core.Entities.ThemeSetting

@{
    ViewData["Title"] = "Tema Detayları";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card card-admin">
            <div class="card-header">
                <h5 class="card-title mb-0">Tema Renk Paleti</h5>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-4 text-center">
                        <div class="rounded shadow-sm mb-2" style="height: 60px; background-color: @Model.MainColor;"></div>
                        <small class="text-muted d-block">Ana Renk</small>
                        <span class="fw-bold font-monospace">@Model.MainColor</span>
                    </div>
                    <div class="col-md-4 text-center">
                        <div class="rounded shadow-sm mb-2" style="height: 60px; background-color: @Model.SecondaryColor;"></div>
                        <small class="text-muted d-block">İkincil Renk</small>
                        <span class="fw-bold font-monospace">@Model.SecondaryColor</span>
                    </div>
                    <div class="col-md-4 text-center">
                        <div class="rounded shadow-sm mb-2 border" style="height: 60px; background-color: @Model.BackgroundColor;"></div>
                        <small class="text-muted d-block">Arkaplan</small>
                        <span class="fw-bold font-monospace">@Model.BackgroundColor</span>
                    </div>
                    <div class="col-md-4 text-center">
                        <div class="rounded shadow-sm mb-2" style="height: 60px; background-color: @Model.TextColor;"></div>
                        <small class="text-muted d-block">Metin Rengi</small>
                        <span class="fw-bold font-monospace">@Model.TextColor</span>
                    </div>
                    <div class="col-md-4 text-center">
                        <div class="rounded shadow-sm mb-2 border" style="height: 60px; background-color: @Model.NavbarBgColor;"></div>
                        <small class="text-muted d-block">Menü Arkaplan</small>
                        <span class="fw-bold font-monospace">@Model.NavbarBgColor</span>
                    </div>
                    <div class="col-md-4 text-center">
                        <div class="rounded shadow-sm mb-2" style="height: 60px; background-color: @Model.FooterBgColor;"></div>
                        <small class="text-muted d-block">Footer Arkaplan</small>
                        <span class="fw-bold font-monospace">@Model.FooterBgColor</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="sticky-form-sidebar">
            <div class="card card-admin">
                <div class="card-header"><h5 class="card-title mb-0">Tema Bilgileri</h5></div>
                <div class="card-body">
                    <dl class="row mb-4">
                        <dt class="col-sm-4 text-muted">Tema Adı</dt>
                        <dd class="col-sm-8 fw-bold">@Model.Name</dd>
                        
                        <dt class="col-sm-4 text-muted">Durum</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Aktif Tema</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pasif</span>
                            }
                        </dd>
                    </dl>
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary shadow-sm"><i class="bi bi-pencil-square me-2"></i> Düzenle</a>
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i> Listeye Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>