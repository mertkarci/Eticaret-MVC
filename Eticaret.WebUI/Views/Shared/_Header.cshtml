@using Eticaret.WebUI.ExtensionMethods
@using Eticaret.Service.Concrete
@using Eticaret.Core.Entities
@{
    ViewData["Title"] = "_Header";

    var cart = Context.Session.GetJson<CartService>("Cart");
    int cartCount = cart?.CartLines.Sum(x => x.Quantity) ?? 0;
    decimal cartTotal = cart?.CartLines.Sum(x => x.Quantity * x.Product.Price) ?? 0;

    var favourites = Context.Session.GetJson<List<Product>>("GetFavourites");
    int favCount = favourites?.Count ?? 0;
    var isFavPage = ViewData["IsFavouritesPage"] as bool? ?? false;
}

<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    
    <style>
        /* ViewComponent'ten gelecek Bootstrap ul/li yapılarını Tailwind ile uyumlu hale getiriyoruz */
        .kategori-menusu { margin: 0; padding: 0; display: flex; align-items: center; gap: 1.5rem; list-style: none; flex-wrap: wrap; }
        .kategori-menusu .nav-item { white-space: nowrap; }
        .kategori-menusu .nav-link { color: #4b5563; font-weight: 500; font-size: 0.9rem; text-decoration: none; transition: color 0.2s; padding: 0.5rem 0; }
        .kategori-menusu .nav-link:hover { color: var(--main-color); }
        html.dark .kategori-menusu .nav-link { color: #d1d5db; }
        html.dark .kategori-menusu .nav-link:hover { color: var(--main-color); }
        
        /* ViewComponent'ten gelen Bootstrap Dropdown sınıflarını Tailwind mantığıyla eziyoruz */
        .dropdown-toggle::after { display: none !important; }
        
        /* Kategoriler Masaüstü Hover */
        @@media (min-width: 1024px) {
           .kategori-menusu .nav-item.dropdown { position: relative; }
           .kategori-menusu .nav-item.dropdown .dropdown-menu { display: none !important; position: absolute !important; left: 0; top: 100%; z-index: 50; background: white; border: 1px solid #e5e7eb; border-radius: 0.5rem; padding: 0.5rem; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); min-width: 200px; margin-top: 0; }
           .kategori-menusu .nav-item.dropdown:hover .dropdown-menu { display: block !important; }
           .kategori-menusu .dropdown-item { padding: 0.5rem 1rem; color: #374151; font-size: 0.875rem; border-radius: 0.25rem; text-decoration: none; display: block; }
           .kategori-menusu .dropdown-item:hover { background-color: #f3f4f6; color: var(--main-color); }
           
           /* Kategori Dark Mode */
           html.dark .kategori-menusu .nav-item.dropdown .dropdown-menu { background: #1e293b; border-color: #334155; }
           html.dark .kategori-menusu .dropdown-item { color: #e2e8f0; }
           html.dark .kategori-menusu .dropdown-item:hover { background-color: #334155; }
        }

        /* İKON DROPDOWN (Sepet, Favori, Profil) - KESİN HOVER VE MOBİL ÇÖZÜMÜ */
        .icon-dropdown {
            position: relative;
        }
        
        /* MOBİL VE TABLET: Hover pencerelerini tamamen kapat, direkt sayfaya yönlendirsin */
        @@media (max-width: 991.98px) {
            .icon-dropdown .dropdown-menu {
                display: none !important;
            }
        }

        /* MASAÜSTÜ: Kusursuz Hover ve Görünmez Köprü */
        @@media (min-width: 992px) {
            .icon-dropdown::after {
                content: '';
                position: absolute;
                top: 100%; /* İkonun tam altından başlar */
                left: -30px; /* Sağa ve sola geniş tolerans */
                right: -30px;
                height: 30px; /* Menüye kadar olan boşluğu tamamen kaplayan görünmez köprü */
                background: transparent;
                z-index: 9999;
            }

            .icon-dropdown .dropdown-menu {
                display: none !important;
                position: absolute !important;
                top: calc(100% + 0.5rem) !important; /* İkondan biraz aşağıda başlar */
                right: 0 !important;
                left: auto !important;
                z-index: 999999 !important;
                margin-top: 0 !important; /* DİKKAT: Margin hover'ı bozar, bu yüzden sıfırladık */
            }

            .icon-dropdown:hover > .dropdown-menu {
                display: flex !important;
                flex-direction: column;
            }
        }
    </style>
</head>

<header class="!bg-white dark:!bg-slate-900 sticky-top shadow-sm transition-colors duration-300 z-[1020]">
    
    <div class="container mx-auto px-4 py-3">
        <div class="flex items-center justify-between gap-4">
            
            <!-- Mobil Hamburger -->
            <button class="lg:hidden text-gray-700 dark:text-gray-200 hover:text-primary transition-colors bg-transparent border-0 p-1" 
                    type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMenuOffcanvas">
                <i class="bi bi-list text-3xl"></i>
            </button>

            <!-- Logo -->
            <a asp-controller="Home" asp-action="Index" 
               class="hidden lg:block text-2xl md:text-3xl font-black tracking-wider text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary no-underline flex-shrink-0">
                SAFU
            </a>

            <!-- Arama -->
            <div class="hidden lg:block flex-1 max-w-2xl mx-6">
                <form asp-controller="Products" asp-action="Index" method="get" class="relative group">
                    <input name="q" type="search" placeholder="Ne aramıştınız? Sitede Ara..." 
                           class="w-full !bg-gray-100 dark:!bg-slate-800 text-gray-800 dark:!text-gray-200 rounded-full py-2.5 pl-6 pr-12 focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all border-none placeholder-gray-400">
                    <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 p-2 text-gray-400 hover:text-primary transition-colors bg-transparent border-0">
                        <i class="bi bi-search text-lg"></i>
                    </button>
                </form>
            </div>

            <!-- İkonlar -->
            <div class="flex items-center gap-1 sm:gap-2">
                
                <button id="theme-toggle" type="button" class="w-10 h-10 flex items-center justify-center rounded-full text-gray-600 dark:!text-gray-300 hover:!bg-gray-100 dark:hover:!bg-slate-800 transition-colors bg-transparent border-0" title="Tema Değiştir">
                    <i id="theme-toggle-dark-icon" class="bi bi-moon-fill text-xl d-none"></i>
                    <i id="theme-toggle-light-icon" class="bi bi-sun-fill text-xl d-none text-yellow-400"></i>
                </button>

                <!-- FAVORİLER DROPDOWN (Eski Bootstrap + Hover CSS Karışımı) -->
                <div class="dropdown icon-dropdown">
                    <a asp-controller="Favourites" asp-action="Index" class="relative w-10 h-10 flex items-center justify-center rounded-full text-gray-600 dark:!text-gray-300 hover:!bg-gray-100 dark:hover:!bg-slate-800 transition-colors group text-decoration-none">
                        <i class="bi @(isFavPage ? "bi-heart-fill text-red-500" : "bi-heart group-hover:text-red-500 transition-colors") text-xl"></i>
                        @if (favCount > 0)
                        {
                            <span class="absolute top-0 right-0 transform translate-x-1/4 -translate-y-1/4 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full border-2 border-white dark:border-slate-900">@favCount</span>
                        }
                    </a>
                    
                    <div class="dropdown-menu dropdown-menu-end !bg-white dark:!bg-slate-800 shadow-2xl border border-gray-100 dark:border-slate-700 rounded-2xl overflow-hidden w-[340px] max-w-[95vw] p-0">
                        @if (favourites != null && favourites.Any())
                        {
                            <div class="!bg-gray-50 dark:!bg-slate-700/50 px-4 py-3 flex justify-between items-center border-b border-gray-100 dark:border-slate-700">
                                <span class="font-bold text-gray-800 dark:!text-white">Favorilerim (@favCount)</span>
                            </div>
                            <div class="max-h-[300px] overflow-y-auto">
                                @foreach (var item in favourites)
                                {
                                    <div class="flex items-center gap-3 p-3 border-b border-gray-50 dark:border-slate-700/50 hover:!bg-gray-50 dark:hover:!bg-slate-700 transition-colors">
                                        <div class="relative flex-shrink-0">
                                            <img src="/img/products/@item.Image" class="w-12 h-12 rounded-lg object-cover border border-gray-100 dark:border-slate-600" />
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <a asp-route="ProductDetail" asp-route-slug="@item.Slug" class="block font-semibold text-sm text-gray-800 dark:!text-gray-200 truncate hover:text-red-500 transition-colors no-underline">
                                                @item.Name
                                            </a>
                                            <div class="text-sm font-bold text-primary mt-0.5">@item.Price.ToString("c")</div>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="p-3 !bg-white dark:!bg-slate-800 border-t border-gray-100 dark:border-slate-700">
                                <a asp-controller="Favourites" asp-action="Index" class="block w-full py-2.5 bg-red-500 hover:bg-red-600 text-white text-center font-bold rounded-xl transition-colors no-underline">
                                    Tüm Favorileri Gör
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="px-4 py-8 text-center">
                                <i class="bi bi-heartbreak text-5xl text-gray-300 dark:!text-gray-600 mb-3 block"></i>
                                <span class="text-gray-500 dark:!text-gray-400 font-medium">Favorileriniz şu an boş.</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- SEPET DROPDOWN (Eski Bootstrap + Hover CSS Karışımı) -->
                <div class="dropdown icon-dropdown">
                    <a asp-controller="Cart" asp-action="Index" class="w-10 h-10 flex items-center justify-center rounded-full text-gray-600 dark:!text-gray-300 hover:!bg-gray-100 dark:hover:!bg-slate-800 transition-colors bg-transparent border-0 relative cursor-pointer text-decoration-none">
                        <i class="bi bi-cart3 text-xl"></i>
                        @if (cartCount > 0)
                        {
                            <span class="absolute top-0 right-0 transform translate-x-1/4 -translate-y-1/4 bg-primary text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full border-2 border-white dark:border-slate-900">@cartCount</span>
                        }
                    </a>
                    
                    <div class="dropdown-menu dropdown-menu-end !bg-white dark:!bg-slate-800 shadow-2xl border border-gray-100 dark:border-slate-700 rounded-2xl overflow-hidden w-[340px] max-w-[95vw] p-0">
                        @if (cart != null && cart.CartLines.Any())
                        {
                            <div class="!bg-gray-50 dark:!bg-slate-700/50 px-4 py-3 flex justify-between items-center border-b border-gray-100 dark:border-slate-700">
                                <span class="font-bold text-gray-800 dark:!text-white">Sepetim (@cartCount)</span>
                                <span class="font-bold text-primary">@cartTotal.ToString("c")</span>
                            </div>
                            <div class="max-h-[300px] overflow-y-auto">
                                @foreach (var item in cart.CartLines)
                                {
                                    <div class="flex items-center gap-3 p-3 border-b border-gray-50 dark:border-slate-700/50 hover:!bg-gray-50 dark:hover:!bg-slate-700 transition-colors">
                                        <div class="relative flex-shrink-0">
                                            <img src="/img/products/@item.Product.Image" class="w-12 h-12 rounded-lg object-cover border border-gray-100 dark:border-slate-600" />
                                            <span class="absolute -top-2 -left-2 bg-gray-500 text-white text-[10px] font-bold px-1.5 rounded-full">@item.Quantity</span>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <a asp-route="ProductDetail" asp-route-slug="@item.Product.Slug" class="block font-semibold text-sm text-gray-800 dark:!text-gray-200 truncate hover:text-primary transition-colors no-underline">
                                                @item.Product.Name
                                            </a>
                                            <div class="text-sm font-bold text-gray-500 mt-0.5">@((item.Product.Price * item.Quantity).ToString("c"))</div>
                                        </div>
                                        <form asp-controller="Cart" asp-action="Remove" method="post" class="m-0">
                                            <input type="hidden" name="ProductId" value="@item.Product.Id">
                                            <button type="submit" class="p-1.5 text-gray-400 hover:text-red-500 hover:!bg-red-50 dark:hover:!bg-red-500/10 rounded-lg transition-all bg-transparent border-0">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                            <div class="p-3 !bg-white dark:!bg-slate-800 border-t border-gray-100 dark:border-slate-700">
                                <a asp-controller="Cart" asp-action="Index" class="block w-full py-2.5 bg-primary hover:bg-secondary text-white text-center font-bold rounded-xl transition-colors no-underline">
                                    Sepete Git
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="px-4 py-8 text-center">
                                <i class="bi bi-cart-x text-5xl text-gray-300 dark:!text-gray-600 mb-3 block"></i>
                                <span class="text-gray-500 dark:!text-gray-400 font-medium">Sepetiniz şu an boş.</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- KULLANICI DROPDOWN (Eski Bootstrap + Hover CSS Karışımı) -->
                <div class="dropdown icon-dropdown">
                    <a asp-controller="Accounts" asp-action="Index" class="w-10 h-10 flex items-center justify-center rounded-full text-gray-600 dark:!text-gray-300 hover:!bg-gray-100 dark:hover:!bg-slate-800 transition-colors bg-transparent border-0 cursor-pointer text-decoration-none">
                        <i class="bi bi-person-circle text-xl"></i>
                    </a>
                    
                    <div class="dropdown-menu dropdown-menu-end !bg-white dark:!bg-slate-800 shadow-2xl border border-gray-100 dark:border-slate-700 rounded-2xl overflow-hidden w-[220px] p-0">
                        @if (Context.User.Identity.IsAuthenticated)
                        {
                            <div class="!bg-gray-50 dark:!bg-slate-700/50 px-4 py-3 text-center border-b border-gray-100 dark:border-slate-700">
                                <span class="block text-xs text-gray-500 dark:!text-gray-400">Hoş geldiniz,</span>
                                <span class="block font-bold text-gray-800 dark:!text-white truncate">@Context.User.Identity.Name</span>
                            </div>
                            <a asp-controller="Accounts" asp-action="Index" class="flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-gray-700 dark:!text-gray-200 hover:!bg-gray-50 dark:hover:!bg-slate-700 hover:text-primary transition-colors no-underline"><i class="bi bi-person-vcard text-primary text-lg"></i> Bilgilerim</a>
                            <a asp-controller="Accounts" asp-action="MyOrders" class="flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-gray-700 dark:!text-gray-200 hover:!bg-gray-50 dark:hover:!bg-slate-700 hover:text-primary transition-colors no-underline"><i class="bi bi-box-seam text-emerald-500 text-lg"></i> Siparişlerim</a>
                            <a asp-controller="MyAddresses" asp-action="Index" class="flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-gray-700 dark:!text-gray-200 hover:!bg-gray-50 dark:hover:!bg-slate-700 hover:text-primary transition-colors no-underline"><i class="bi bi-geo-alt text-blue-500 text-lg"></i> Adreslerim</a>
                            <div class="h-px !bg-gray-100 dark:!bg-slate-700 my-1"></div>
                            <a asp-controller="Accounts" asp-action="SignOut" class="flex items-center gap-3 px-4 py-2.5 text-sm font-bold text-red-500 hover:!bg-red-50 dark:hover:!bg-red-500/10 transition-colors no-underline"><i class="bi bi-box-arrow-right text-lg"></i> Çıkış Yap</a>
                        }
                        else
                        {
                            <a asp-controller="Accounts" asp-action="SignIn" class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-gray-700 dark:!text-gray-200 hover:!bg-gray-50 dark:hover:!bg-slate-700 hover:text-primary transition-colors no-underline"><i class="bi bi-box-arrow-in-right text-primary text-lg"></i> Giriş Yap</a>
                            <a asp-controller="Accounts" asp-action="SignUp" class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-gray-700 dark:!text-gray-200 hover:!bg-gray-50 dark:hover:!bg-slate-700 hover:text-primary transition-colors no-underline"><i class="bi bi-person-plus text-emerald-500 text-lg"></i> Kayıt Ol</a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:hidden mt-3 pb-1">
            <form asp-controller="Products" asp-action="Index" method="get" class="relative group w-full">
                <input name="q" type="search" placeholder="Sitede Ara..." 
                       class="w-full !bg-gray-100 dark:!bg-slate-800 text-gray-800 dark:!text-gray-200 rounded-full py-2.5 pl-5 pr-12 focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all border-none placeholder-gray-400">
                <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 p-2 text-gray-400 hover:text-primary transition-colors bg-transparent border-0">
                    <i class="bi bi-search"></i>
                </button>
            </form>
        </div>
    </div>

    <!-- ALT BÖLÜM -->
    <div class="hidden lg:block border-t border-gray-100 dark:border-slate-800 !bg-gray-50 dark:!bg-slate-900">
        <div class="container mx-auto px-4">
            <ul class="kategori-menusu">
                @await Component.InvokeAsync("Categories")
                <li class="nav-item ms-auto">
                    <a asp-controller="Home" asp-action="ContactUs" class="nav-link font-bold text-gray-500 hover:text-primary"><i class="bi bi-headset me-1"></i> İletişim</a>
                </li>
            </ul>
        </div>
    </div>
</header>

<div class="offcanvas offcanvas-start dark:!bg-slate-900 border-r-0 shadow-2xl" tabindex="-1" id="mobileMenuOffcanvas">
    <div class="offcanvas-header border-b border-gray-100 dark:border-slate-800 py-4">
        <h5 class="offcanvas-title font-black text-2xl text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">SAFU</h5>
        <button type="button" class="btn-close dark:filter dark:invert" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-0">
        <ul class="kategori-menusu flex-col items-start gap-0 p-4">
            <div class="w-full [&>li]:border-b [&>li]:border-gray-100 dark:[&>li]:border-slate-800 [&>li>a]:py-3 [&>li>a]:block [&>li>a]:w-full">
                @await Component.InvokeAsync("Categories")
                <li class="nav-item mt-4 border-none border-t pt-4">
                    <a asp-controller="Home" asp-action="ContactUs" class="nav-link text-primary font-bold"><i class="bi bi-headset me-2"></i> Bize Ulaşın</a>
                </li>
            </div>
        </ul>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        var themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
        var themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');

        if (!themeToggleDarkIcon || !themeToggleLightIcon) return;

        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            themeToggleLightIcon.classList.remove('d-none');
        } else {
            themeToggleDarkIcon.classList.remove('d-none');
        }

        var themeToggleBtn = document.getElementById('theme-toggle');
        themeToggleBtn.addEventListener('click', function() {
            themeToggleDarkIcon.classList.toggle('d-none');
            themeToggleLightIcon.classList.toggle('d-none');

            document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
        });
    });
</script>
