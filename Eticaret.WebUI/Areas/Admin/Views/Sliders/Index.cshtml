@model IEnumerable<Eticaret.Core.Entities.Slider>

@{
    ViewData["Title"] = "Slider Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Create" class="btn btn-create shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Yeni Slider Ekle
    </a>
</div>

<div class="card card-admin">
    <div class="card-body">
        <table id="datatablesSimple" class="table-admin table-hover">
            <thead>
                <tr>
                    <th class="ps-4">Görsel</th>
                    <th>@Html.DisplayNameFor(model => model.Title)</th>
                    <th>@Html.DisplayNameFor(model => model.Link)</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            @if (!string.IsNullOrEmpty(item.Image))
                            {
                                <img src="/img/sliders/@item.Image" alt="@item.Title" class="rounded shadow-sm" style="width: 100px; height: 40px; object-fit: cover;" />
                            }
                            else
                            {
                                <span class="text-muted small">Görsel Yok</span>
                            }
                        </td>
                        <td class="fw-bold text-dark">@Html.DisplayFor(modelItem => item.Title)</td>
                        <td>
                            <a href="@item.Link" target="_blank" class="text-decoration-none text-truncate d-block" style="max-width: 200px;">
                                @Html.DisplayFor(modelItem => item.Link)
                            </a>
                        </td>
                        <td class="text-end pe-4">
                            <div class="action-buttons">
                                <a asp-action="Edit" class="btn btn-outline-primary" asp-route-id="@item.Id" title="Düzenle">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="Delete" class="btn btn-outline-danger" asp-route-id="@item.Id" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>