@model IEnumerable<Eticaret.Core.Entities.Address>

@{
    ViewData["Title"] = "Adreslerim";
}

<div class="container py-4 py-md-5">
    @* --- ÜST BAŞLIK --- *@
    <div class="d-flex align-items-center justify-content-between mb-4 mb-md-5">
        <div>
            <h2 class="fw-bold text-dark mb-1">Adreslerim</h2>
            <p class="text-muted small mb-0">Kayıtlı adreslerinizi buradan yönetebilirsiniz.</p>
        </div>
        @* Masaüstü için hızlı ekle butonu *@
        <a asp-controller="MyAddresses" asp-action="Create" class="btn btn-primary rounded-pill px-4 d-none d-md-inline-block">
            <i class="bi bi-plus-lg me-1"></i> Yeni Adres
        </a>
    </div>

    @if (!Model.Any())
    {
        @* --- BOŞ DURUM (EMPTY STATE) --- *@
        <div class="d-flex flex-column justify-content-center align-items-center text-center py-5" style="min-height: 65vh;">
            <div class="mb-3">
                <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                    <i class="bi bi-geo-alt text-muted fs-1"></i>
                </div>
            </div>
            <h4 class="fw-bold text-dark">Henüz adres eklemediniz</h4>
            <p class="text-muted mb-4">Siparişlerinizi daha hızlı tamamlamak için adres ekleyin.</p>
            <a asp-controller="MyAddresses" asp-action="Create" class="btn btn-primary rounded-pill px-4">
                Adres Ekle
            </a>
        </div>
    }
    else
    {
        <div class="letter-paper shadow-sm p-3 p-md-5" style="min-height: 65vh;">
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        @* --- ADRES KARTI --- *@
                        @* Dinamik Linkleme: onclick yerine görünmez bir link (stretched-link) kullanmak daha SEO dostudur *@
                        <div class="card h-100 border-0 shadow-sm address-card position-relative">
                            
                            @* Düzenleme Linki (Bütün karta yayılır) *@
                            <a asp-controller="MyAddresses" asp-action="Edit" asp-route-name="@item.Title" class="stretched-link"></a>

                            @if (item.IsActive)
                            {
                                <div class="position-absolute top-0 end-0 mt-3 me-3" style="z-index: 2;">
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3">Aktif</span>
                                </div>
                            }

                            <div class="card-body p-4 d-flex flex-column">
                                <div class="d-flex align-items-center mb-4">
                                    <div class="icon-box bg-light text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                        <i class="bi bi-house-door-fill fs-5"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold text-dark mb-0">@item.Title</h6>
                                        <small class="text-muted">@item.City / @item.District</small>
                                    </div>
                                </div>

                                <div class="mb-4 flex-grow-1">
                                    <p class="text-secondary small mb-0" style="line-height: 1.6;">
                                        @item.OpenAddress
                                    </p>
                                </div>

                                <div class="d-flex align-items-center justify-content-between pt-3 border-top border-light" style="z-index: 2;">
                                    <div class="d-flex gap-2">
                                        @if (item.IsDeliveryAddress)
                                        {
                                            <span class="badge bg-light text-secondary border fw-normal" title="Teslimat Adresi"><i class="bi bi-truck"></i></span>
                                        }
                                        @if (item.IsBillingAddress)
                                        {
                                            <span class="badge bg-light text-secondary border fw-normal" title="Fatura Adresi"><i class="bi bi-receipt"></i></span>
                                        }
                                    </div>
                                    @* Silme Butonu *@
                                    <a asp-controller="MyAddresses" asp-action="Delete" asp-route-name="@item.Title"
                                       class="btn btn-sm btn-outline-danger rounded-pill px-3 py-0 position-relative">
                                        <i class="bi bi-trash me-1"></i> Sil
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @* --- YENİ ADRES EKLE KARTI --- *@
                <div class="col-md-6 col-lg-4">
                    <a asp-controller="MyAddresses" asp-action="Create"
                        class="card h-100 border-2 border-dashed border-light bg-transparent text-decoration-none d-flex align-items-center justify-content-center p-4 address-add-card">
                        <div class="text-center text-muted">
                            <i class="bi bi-plus-circle fs-3 mb-2 d-block"></i>
                            <span class="fw-medium">Yeni Adres Ekle</span>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    }
</div>