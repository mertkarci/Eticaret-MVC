@model Eticaret.Core.Entities.AppUser
@{
    ViewData["Title"] = "Yeni Hesap Oluştur";
}

<div class="container py-4 my-md-5 d-flex flex-column justify-content-center align-items-center">
    
    <div class="col-12 col-md-8 col-lg-6 col-xl-5">
        
        <div class="card login-card">
            <div class="card-body p-4 p-sm-5">
                
                <div class="brand-icon-wrapper">
                    <i class="bi bi-person-plus-fill fs-1"></i>
                </div>

                <div class="text-center mb-4">
                    <h2 class="fw-bold text-dark mb-1">Yeni Hesap Oluştur</h2>
                    <p class="text-muted">Hızlı ve güvenli alışverişe başlamak için kayıt olun.</p>
                </div>

                <form asp-action="SignUp" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>
                    
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <div class="form-floating">
                                <input asp-for="Name" class="form-control" id="floatingName" placeholder="Adınız" required />
                                <label for="floatingName">Adınız</label>
                                <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-floating">
                                <input asp-for="Surname" class="form-control" id="floatingSurname" placeholder="Soyadınız" required />
                                <label for="floatingSurname">Soyadınız</label>
                                <span asp-validation-for="Surname" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" type="email" class="form-control" id="floatingEmail" placeholder="name@example.com" required />
                        <label for="floatingEmail">E-Posta Adresi</label>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Phone" type="tel" class="form-control" id="floatingPhone" placeholder="05XX XXX XX XX" required />
                        <label for="floatingPhone">Cep Telefonu</label>
                        <span asp-validation-for="Phone" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Password" type="password" class="form-control" id="floatingPassword" placeholder="Şifre" required>
                        <label for="floatingPassword">Şifre Belirleyin</label>
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-check mb-4 small">
                        <input class="form-check-input shadow-sm" type="checkbox" id="terms" required />
                        <label class="form-check-label text-muted user-select-none" for="terms">
                            <a href="#" class="text-primary text-decoration-none">Üyelik Sözleşmesi</a>'ni ve <a href="#" class="text-primary text-decoration-none">Aydınlatma Metni</a>'ni okudum ve kabul ediyorum.
                        </label>
                    </div>

                    <button class="btn btn-primary w-100 rounded-pill shadow-sm" type="submit">
                        Kayıt Ol <i class="bi bi-person-check-fill ms-1"></i>
                    </button>
                </form>

            </div>
            
            <div class="card-footer bg-light text-center py-4">
                <span class="text-muted small">Zaten bir hesabınız var mı?</span>
                <a asp-action="SignIn" asp-controller="Accounts" class="text-primary text-decoration-none fw-bold ms-1">
                    Giriş Yap
                </a>
            </div>
        </div>

    </div>
</div>