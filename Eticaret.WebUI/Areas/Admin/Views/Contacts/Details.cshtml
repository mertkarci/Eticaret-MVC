@model Eticaret.Core.Entities.Contact

@{
    ViewData["Title"] = "İletişim Mesajı Detayı";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-admin">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Mesaj Detayları</h5>
                <small class="text-muted">@Model.CreateDate.ToString("dd.MM.yyyy HH:mm")</small>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="text-muted small">Gönderen</label>
                        <div class="fw-bold">@Model.Name @Model.Surname</div>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <label class="text-muted small">İletişim</label>
                        <div><a href="mailto:@Model.Email">@Model.Email</a></div>
                        <div><a href="tel:@Model.Phone">@Model.Phone</a></div>
                    </div>
                </div>
                
                <hr />
                
                <div class="mb-3">
                    <label class="text-muted small mb-2">Mesaj İçeriği</label>
                    <div class="p-3 bg-light rounded border">
                        @Model.Message
                    </div>
                </div>
                
                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Listeye Dön</a>
                    <a href="mailto:@Model.Email" class="btn btn-primary"><i class="bi bi-reply-fill me-1"></i> Yanıtla</a>
                </div>
            </div>
        </div>
    </div>
</div>