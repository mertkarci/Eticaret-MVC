@model Eticaret.Core.Entities.Product

@{
    ViewData["Title"] = "Ürün Detayları";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card card-admin">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Ürün Bilgileri</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted">Ürün Adı</dt>
                    <dd class="col-sm-9 fw-bold text-dark">@Model.Name</dd>

                    <dt class="col-sm-3 text-muted">Kalıcı Bağlantı</dt>
                    <dd class="col-sm-9">
                        <code class="text-primary">/urun/@Model.Slug</code>
                        <a href="/urun/@Model.Slug" target="_blank" class="ms-2 text-decoration-none small">
                            <i class="bi bi-box-arrow-up-right"></i> Sitede Gör
                        </a>
                    </dd>

                    <dt class="col-sm-3 text-muted">Ürün Kodu</dt>
                    <dd class="col-sm-9">@Model.ProductCode</dd>

                    <dt class="col-sm-3 text-muted">Açıklama</dt>
                    <dd class="col-sm-9">@Model.Description</dd>

                    <dt class="col-sm-3 text-muted">Fiyat</dt>
                    <dd class="col-sm-9 fs-5 text-primary fw-bold">@Model.Price.ToString("c")</dd>

                    <dt class="col-sm-3 text-muted">Stok</dt>
                    <dd class="col-sm-9">@Model.Stock Adet</dd>

                    <dt class="col-sm-3 text-muted">Kategori</dt>
                    <dd class="col-sm-9">@Model.Category?.Name</dd>

                    <dt class="col-sm-3 text-muted">Marka</dt>
                    <dd class="col-sm-9">@Model.Brand?.Name</dd>

                    <dt class="col-sm-3 text-muted">Oluşturulma</dt>
                    <dd class="col-sm-9">@Model.CreateDate.ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="sticky-form-sidebar">
            <div class="card card-admin mb-4">
                <div class="card-header"><h5 class="card-title mb-0">Ürün Görseli</h5></div>
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.Image))
                    {
                        <img src="/img/products/@Model.Image" alt="@Model.Name" class="img-fluid rounded shadow-sm" style="max-height: 250px;" />
                    }
                    else
                    {
                        <div class="text-muted py-4">
                            <i class="bi bi-image fs-1 d-block mb-2"></i>
                            Görsel Yok
                        </div>
                    }
                </div>
            </div>

            <div class="card card-admin">
                <div class="card-header"><h5 class="card-title mb-0">Durum</h5></div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                        <span>Aktiflik Durumu:</span>
                        @if (Model.isActive)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span>Anasayfa Gösterimi:</span>
                        @if (Model.isHome)
                        {
                            <span class="badge bg-primary">Evet</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-dark border">Hayır</span>
                        }
                    </div>
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary shadow-sm"><i class="bi bi-pencil-square me-2"></i> Düzenle</a>
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i> Listeye Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>