@model Eticaret.Core.Entities.ProductImage

@{
    ViewData["Title"] = "Görsel Detayı";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card card-admin mb-4">
            <div class="card-header"><h5 class="card-title mb-0">Görsel Önizleme</h5></div>
            <div class="card-body text-center bg-light">
                @if (!string.IsNullOrEmpty(Model.Name))
                {
                    <img src="/img/products/@Model.Name" alt="@Model.Alt" class="img-fluid rounded shadow-sm" style="max-height: 400px;" />
                }
                else
                {
                    <div class="text-muted py-5">Görsel Bulunamadı</div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="sticky-form-sidebar">
            <div class="card card-admin">
                <div class="card-header"><h5 class="card-title mb-0">Görsel Bilgileri</h5></div>
                <div class="card-body">
                    <dl class="row mb-4">
                        <dt class="col-sm-4 text-muted">Dosya Adı</dt>
                        <dd class="col-sm-8 text-break">@Model.Name</dd>

                        <dt class="col-sm-4 text-muted">Alt Etiketi</dt>
                        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Alt) ? "-" : Model.Alt)</dd>

                        <dt class="col-sm-4 text-muted">Ürün</dt>
                        <dd class="col-sm-8">
                            <a href="/Admin/Products/Details/@Model.ProductId" class="text-decoration-none">@Model.Product?.Name</a>
                        </dd>
                    </dl>
                    
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary shadow-sm"><i class="bi bi-pencil-square me-2"></i> Düzenle</a>
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i> Listeye Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>