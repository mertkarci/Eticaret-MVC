@model Eticaret.Core.Entities.Order

@{
    ViewData["Title"] = $"Sipariş #{Model.OrderNumber}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0 text-dark">Sipariş Detayı</h4>
        <p class="text-muted small mb-0">@Model.OrderDate.ToString("dd MMMM yyyy, HH:mm") tarihinde oluşturuldu.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm rounded-pill px-4">
        <i class="bi bi-arrow-left me-2"></i> Listeye Dön
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        
        <div class="card card-admin mb-4 border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <h5 class="card-title mb-0 fw-bold"><i class="bi bi-box-seam text-primary me-2"></i>Sipariş İçeriği</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 py-3 text-muted">Ürün</th>
                                <th class="text-center py-3 text-muted">Adet</th>
                                <th class="text-end pe-4 py-3 text-muted">Birim Fiyat</th>
                                <th class="text-end pe-4 py-3 text-muted">Toplam</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.OrderLines != null && Model.OrderLines.Any())
                            {
                                @foreach (var item in Model.OrderLines)
                                {
                                    <tr>
                                        <td class="ps-4 py-3">
                                            <span class="fw-medium text-dark">@item.Product?.Name</span>
                                        </td>
                                        <td class="text-center py-3">
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3">@item.Quantity</span>
                                        </td>
                                        <td class="text-end pe-4 py-3 text-muted">@item.UnitPrice.ToString("c")</td>
                                        <td class="text-end pe-4 py-3 fw-bold text-dark">@((item.Quantity * item.UnitPrice).ToString("c"))</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">Bu siparişte ürün bulunamadı.</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="bg-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold py-3 text-dark">Genel Toplam:</td>
                                <td class="text-end pe-4 fw-bold text-success fs-5 py-3">@Model.TotalPrice.ToString("c")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="card card-admin h-100 border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="card-title mb-0 fw-bold"><i class="bi bi-truck text-primary me-2"></i>Teslimat Adresi</h6>
                    </div>
                    <div class="card-body text-muted" style="line-height: 1.6;">
                        @if (!string.IsNullOrEmpty(Model.DeliveryAddress))
                        {
                            @Model.DeliveryAddress
                        }
                        else
                        {
                            <span class="text-danger fst-italic">Belirtilmemiş</span>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card card-admin h-100 border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="card-title mb-0 fw-bold"><i class="bi bi-receipt text-primary me-2"></i>Fatura Adresi</h6>
                    </div>
                    <div class="card-body text-muted" style="line-height: 1.6;">
                        @if (!string.IsNullOrEmpty(Model.BillingAddress))
                        {
                            @Model.BillingAddress
                        }
                        else
                        {
                            <span class="text-danger fst-italic">Belirtilmemiş</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="sticky-form-sidebar">
            
            <div class="card card-admin mb-4 border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="card-title mb-0 fw-bold"><i class="bi bi-info-circle text-primary me-2"></i>Sipariş Özeti</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted">Sipariş No:</span>
                        <span class="fw-bold fs-5 text-dark">#@Model.OrderNumber</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Durum:</span>
                        @switch (Model.OrderState)
                        {
                            case Eticaret.Core.Entities.EnumOrderState.Waiting:
                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Onay Bekliyor</span>
                                break;
                            case Eticaret.Core.Entities.EnumOrderState.Approved:
                                <span class="badge bg-info px-3 py-2 rounded-pill">Onaylandı</span>
                                break;
                            case Eticaret.Core.Entities.EnumOrderState.Shipped:
                                <span class="badge bg-primary px-3 py-2 rounded-pill">Kargoda</span>
                                break;
                            case Eticaret.Core.Entities.EnumOrderState.Completed:
                                <span class="badge bg-success px-3 py-2 rounded-pill">Tamamlandı</span>
                                break;
                            case Eticaret.Core.Entities.EnumOrderState.Rejected:
                                <span class="badge bg-danger px-3 py-2 rounded-pill">Reddedildi</span>
                                break;
                            default:
                                <span class="badge bg-secondary px-3 py-2 rounded-pill">Belirsiz</span>
                                break;
                        }
                    </div>
                </div>
            </div>

            <div class="card card-admin mb-4 border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="card-title mb-0 fw-bold"><i class="bi bi-person-lines-fill text-primary me-2"></i>Müşteri Bilgileri</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        @if (Model.AppUserId != null)
                        {
                            <a asp-controller="AppUsers" asp-action="Details" asp-route-id="@Model.AppUserId" class="btn btn-sm btn-warning w-100 rounded-pill mb-2 shadow-sm">
                                <i class="bi bi-person-check-fill me-1"></i> Kayıtlı Üye: @Model.CustomerName
                            </a>
                        }
                        else
                        {
                            <div class="bg-light border text-center p-2 rounded-pill mb-2">
                                <i class="bi bi-person-badge text-secondary me-1"></i> <span class="fw-medium text-dark">Misafir: @Model.CustomerName</span>
                            </div>
                        }
                    </div>

                    <ul class="list-unstyled mb-0">
                        <li class="mb-2 d-flex align-items-center">
                            <i class="bi bi-envelope text-muted me-2"></i>
                            <a href="mailto:@Model.CustomerEmail" class="text-decoration-none text-dark">@Model.CustomerEmail</a>
                        </li>
                        <li class="d-flex align-items-center">
                            <i class="bi bi-telephone text-muted me-2"></i>
                            <a href="tel:@Model.CustomerPhone" class="text-decoration-none text-dark">@(string.IsNullOrEmpty(Model.CustomerPhone) ? "Belirtilmemiş" : Model.CustomerPhone)</a>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card card-admin border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary rounded-pill shadow-sm py-2">
                            <i class="bi bi-pencil-square me-2"></i> Siparişi Düzenle
                        </a>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>