@using Eticaret.WebUI.ExtensionMethods
@model ProductDetailViewModel
@using Microsoft.AspNetCore.RateLimiting @* Rate Limit kalkanı için gerekli *@

@{
    ViewData["Title"] = Model.Product.Name;
    var favourites = Context.Session.GetJson<List<Product>>("GetFavourites") ?? new List<Product>();
}

@* CSS kısımları aynı kalacak... *@

<section class="py-5">
    <div class="container px-4 px-lg-5 my-4">

        @* --- BREADCRUMB DİNAMİKLEŞTİRİLDİ --- *@
        <nav aria-label="breadcrumb" class="mb-5">
            <ol class="breadcrumb bg-transparent p-0 m-0">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">
                        <i class="bi bi-house-door"></i> Ana Sayfa
                    </a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-controller="Products" asp-action="Index" class="text-decoration-none text-muted">Ürünler</a>
                </li>
                <li class="breadcrumb-item active fw-bold text-dark" aria-current="page">@Model.Product.Name</li>
            </ol>
        </nav>

        <div class="row gx-5 align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="product-image-wrapper">
                    <partial name="_ProductImageGallery" model="Model.Product" />
                </div>
            </div>

            <div class="col-lg-6 ps-lg-5">
                <div class="badge bg-dark text-white mb-3 px-3 py-2 rounded-pill shadow-sm">
                    Ürün Kodu: @Model.Product.Id
                </div>

                <h1 class="product-title fw-bold mb-3 text-dark">@Model.Product.Name</h1>

                <div class="d-flex align-items-end mb-4 bg-light p-3 rounded-4 border">
                    <div class="me-3">
                        <span class="d-block text-muted text-decoration-line-through small mb-1">
                            Eski Fiyat: @((Model.Product.Price * 1.2m).ToString("c"))
                        </span>
                        <span class="display-6 fw-bold text-primary">@Model.Product.Price.ToString("c")</span>
                    </div>
                    <div class="pb-1">
                        <span class="badge bg-success text-white px-2 py-1"><i class="bi bi-truck me-1"></i> Ücretsiz Kargo</span>
                    </div>
                </div>

                <div class="description-box mb-5 shadow-sm text-secondary">
                    <h6 class="text-dark fw-bold mb-2"><i class="bi bi-info-circle me-2"></i>Ürün Açıklaması</h6>
                    <p class="m-0" style="line-height: 1.7;">@Model.Product.Description</p>
                </div>

                @* --- MOBİL MİKTAR VE FAVORİ ALANI --- *@
                <div class="d-lg-none mb-4">
                    <div class="d-flex align-items-center justify-content-between gap-3">
                        <div class="input-group shadow-sm rounded-pill overflow-hidden" style="width: 140px; border: 1px solid #e2e8f0;">
                            <button class="btn qty-btn" type="button" onclick="decreaseQty()">-</button>
                            <input class="form-control text-center qty-input px-0" type="number" value="1" min="1" readonly />
                            <button class="btn qty-btn" type="button" onclick="increaseQty()">+</button>
                        </div>

                        <form asp-controller="Favourites" asp-action="Add" method="post" class="m-0">
                            <input type="hidden" name="productId" value="@Model.Product.Id">
                            <button class="btn btn-outline-danger shadow-sm rounded-circle d-flex align-items-center justify-content-center" type="submit" style="width: 50px; height: 50px;">
                                @if (favourites.Any(x => x.Id == Model.Product.Id))
                                {
                                    <i class="bi bi-heart-fill fs-4"></i>
                                }
                                else
                                {
                                    <i class="bi bi-heart fs-4"></i>
                                }
                            </button>
                        </form>
                    </div>
                </div>

                @* --- MASAÜSTÜ SEPETE EKLE ALANI --- *@
                <div class="d-none d-lg-flex align-items-center gap-3">
                    <form asp-controller="Cart" asp-action="Add" method="post" class="d-flex align-items-center gap-3 flex-fill">
                        <input type="hidden" name="ProductId" value="@Model.Product.Id">

                        <div class="input-group shadow-sm rounded-pill overflow-hidden flex-shrink-0" style="width: 130px; border: 1px solid #e2e8f0;">
                            <button class="btn qty-btn" type="button" onclick="decreaseQty()">-</button>
                            <input class="form-control text-center qty-input px-0" name="quantity" type="number" value="1" min="1" readonly />
                            <button class="btn qty-btn" type="button" onclick="increaseQty()">+</button>
                        </div>

                        <button class="btn btn-primary btn-lg flex-fill rounded-pill shadow" type="submit">
                            <i class="bi bi-cart-plus-fill me-2 fs-5"></i> <span class="fw-bold">Hemen Sepete Ekle</span>
                        </button>
                    </form>

                    <form asp-controller="Favourites" asp-action="Add" method="post" class="m-0">
                        <input type="hidden" name="productId" value="@Model.Product.Id">
                        <button class="btn btn-outline-danger shadow-sm rounded-circle d-flex align-items-center justify-content-center transition-all"
                                type="submit" style="width: 54px; height: 54px;" 
                                data-bs-toggle="tooltip" data-bs-placement="top" 
                                title="@(favourites.Any(x => x.Id == Model.Product.Id) ? "Favorilerimden Çıkar" : "Favorilere Ekle")">
                            <i class="bi @(favourites.Any(x => x.Id == Model.Product.Id) ? "bi-heart-fill" : "bi-heart") fs-4"></i>
                        </button>
                    </form>
                </div>

                <div class="d-flex align-items-center mt-4 pt-4 border-top text-muted small">
                    <div class="me-4"><i class="bi bi-shield-check text-success fs-5 me-1"></i> Güvenli Ödeme</div>
                    <div class="me-4"><i class="bi bi-arrow-counterclockwise text-primary fs-5 me-1"></i> 14 Gün İade</div>
                    <div><i class="bi bi-award text-warning fs-5 me-1"></i> 2 Yıl Garanti</div>
                </div>
            </div>
        </div>
    </div>
</section>

@* --- İLGİLİ ÜRÜNLER ALANI --- *@
<section class="py-5 related-section">
    <div class="container px-4 px-lg-5 mt-4">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <span class="text-primary fw-bold text-uppercase tracking-wider small"><i class="bi bi-stars"></i> Sizin İçin Seçtiklerimiz</span>
                <h2 class="fw-bold m-0 mt-2 display-6">Bunları da Beğenebilirsiniz</h2>
            </div>
            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark rounded-pill px-4 d-none d-md-inline-block">
                Tümünü İncele <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>

        <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
            @if (Model.RelatedProducts != null && Model.RelatedProducts.Any())
            {
                @foreach (var item in Model.RelatedProducts)
                {
                    <div class="col mb-5">
                        <partial name="_ProductView" model="item" />
                    </div>
                }
            }
        </div>
    </div>
</section>

@* --- MOBIL STICKY BOTTOM BAR --- *@
<div class="mobile-bottom-bar d-lg-none">
    <div>
        <span class="d-block text-muted small" style="font-size: 0.75rem;">Birim Fiyat</span>
        <span class="fw-bold text-primary fs-4">@Model.Product.Price.ToString("c")</span>
    </div>
    <form asp-controller="Cart" asp-action="Add" method="post" class="flex-fill">
        <input type="hidden" name="ProductId" value="@Model.Product.Id">
        <input type="hidden" name="quantity" id="mobileQtyInput" value="1">
        <button class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-sm" type="submit" onclick="syncQty()">
            Sepete Ekle
        </button>
    </form>
</div>