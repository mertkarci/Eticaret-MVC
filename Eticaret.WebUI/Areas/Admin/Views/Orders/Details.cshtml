@model Eticaret.Core.Entities.Order

@{
    ViewData["Title"] = "Sipariş Detayları";
}

<h1>Detaylar</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.OrderNumber)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.OrderNumber)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.TotalPrice)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.TotalPrice)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.OrderDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.OrderDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.AppUserId)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.AppUserId)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.AppUser)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.AppUser.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.BillingAddress)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.BillingAddress)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DeliveryAddress)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DeliveryAddress)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.OrderLines)
        </dt>
            <dt class="col-sm-2">
            @Html.DisplayFor(model => model.OrderState)
        </dt>
        <dd class="col-sm-10">
            @if (Model.OrderLines.Any())
            {
                <table class="table table-sm">
                    <tr>
                        <table class="table table-borderless border-bottom">
                            <thead class="border-bottom">
                                <tr>
                                    <th>Ürün</th>
                                    <th>Fiyat</th>
                                    <th>Miktar</th>
                                    <th>Toplam</th>
                                    <th>Toplam Fiyat</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item2 in Model.OrderLines)
                                {
                                    <tr class="border-bottom">
                                        <td class="py-3">
                                            <img src="~/img/products/@item2.Product.Image" width="40" class="me-2" />
                                            @item2.Product.Name
                                        </td>
                                        <td class="py-3">@item2.UnitPrice.ToString("c")</td>
                                        <td class="py-3">@item2.Quantity</td>
                                        <td class="py-3">@((item2.UnitPrice * item2.Quantity).ToString("c"))</td>
                                    </tr>
                                }
                                <tr class="border-bottom">
                                    <td colspan="py-3">

                                    </td>
                                    <td colspan="py-3">

                                    </td>
                                    <td colspan="py-3">

                                    </td>
                                    <td colspan="py-3">

                                    </td>
                                    <td colspan="py-3">
                                        @Model.TotalPrice.ToString("c")
                                    </td>
                                </tr>

                            </tbody>
                        </table>
                </table>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" class="btn btn-primary mt-2" sp-route-id="@Model?.Id">Düzenle</a>
    <a asp-action="Index" class="btn btn-danger mt-2">Geri Dön</a>
</div>