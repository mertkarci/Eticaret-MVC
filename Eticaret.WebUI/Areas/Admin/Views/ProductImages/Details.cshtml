@model Eticaret.Core.Entities.ProductImage

@{
    ViewData["Title"] = "Detaylar";
}


<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class="col-sm-2">
        </dt>
        <dd class="col-sm-10">
            <img src="/img/products/@Html.DisplayFor(model => model.Name)" height="100" alt="">
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Alt)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Alt)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Product)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Product.Id)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" class="btn btn-primary mt-2" asp-route-id="@Model?.Id">Düzenle</a>
    <a asp-action="Index" class="btn btn-danger mt-2">Geri Dön</a>
</div>