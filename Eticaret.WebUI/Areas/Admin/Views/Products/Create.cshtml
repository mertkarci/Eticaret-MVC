@model Eticaret.Core.Entities.Product

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
}

<form asp-action="Create" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="row g-4">
        <!-- SOL KOLON: Ana İçerik -->
        <div class="col-lg-8">
            <!-- Ürün Detayları -->
            <div class="card card-admin">
                <div class="card-header">
                    <h5 class="card-title mb-0">Ürün Detayları</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        @* id="ProductName" eklendi *@
                        <input asp-for="Name" id="ProductName" class="form-control form-control-lg"
                            placeholder="Ürün adını giriniz..." />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Slug" class="form-label">Kalıcı Bağlantı (Slug)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted small">/urun/</span>
                            @* id="ProductSlug" eklendi *@
                            <input asp-for="Slug" id="ProductSlug" class="form-control"
                                placeholder="urun-adi-formatinda" />
                        </div>
                        <div class="form-text small text-muted">URL'de görünecek olan benzersiz metin. Boş bırakırsanız
                            isimden üretilir.</div>
                        <span asp-validation-for="Slug" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                    <div class="mb-0">
                        <label asp-for="ProductCode" class="form-label"></label>
                        <input asp-for="ProductCode" class="form-control" />
                        <span asp-validation-for="ProductCode" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Görsel Yükleme -->
            <div class="card card-admin mt-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Ürün Görseli</h5>
                </div>
                <div class="card-body">
                    <label for="file-upload" class="custom-file-upload-container">
                        <div class="icon"><i class="bi bi-cloud-arrow-up-fill"></i></div>
                        <div class="text">
                            <span>Görsel seçmek için tıklayın veya sürükleyip bırakın</span>
                        </div>
                        <input id="file-upload" asp-for="Image" type="file" onchange="previewImage(event)" />
                    </label>
                    <img id="image-preview" src="#" alt="Görsel Önizleme" />
                    <span asp-validation-for="Image" class="text-danger small mt-2 d-block"></span>
                </div>
            </div>

            <!-- Fiyatlandırma ve Stok -->
            <div class="card card-admin mt-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Fiyat ve Stok</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">₺</span>
                                <input asp-for="Price" class="form-control" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Stock" class="form-label"></label>
                            <input asp-for="Stock" class="form-control" />
                            <span asp-validation-for="Stock" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Organizasyon -->
            <div class="card card-admin mt-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Organizasyon</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label"></label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                                <option value="">Kategori Seçiniz</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BrandId" class="form-label"></label>
                            <select asp-for="BrandId" class="form-select" asp-items="ViewBag.BrandId">
                                <option value="">Marka Seçiniz</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SAĞ KOLON: Eylemler ve Durum -->
        <div class="col-lg-4">
            <div class="sticky-form-sidebar">
                <!-- Eylemler -->
                <div class="card card-admin">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Eylemler</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-submit shadow-sm">
                                <i class="bi bi-plus-circle me-2"></i> Ürünü Oluştur
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-2"></i> İptal Et ve Geri Dön
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Durum -->
                <div class="card card-admin mt-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Durum</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" asp-for="isActive" />
                            <label class="form-check-label" asp-for="isActive">@Html.DisplayNameFor(model =>
                                                                model.isActive)</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" asp-for="isHome" />
                            <label class="form-check-label" asp-for="isHome">@Html.DisplayNameFor(model =>
                                                                model.isHome)</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Görsel Önizleme Fonksiyonun
        function previewImage(event) {
            const reader = new FileReader();
            reader.onload = function () {
                const output = document.getElementById('image-preview');
                output.src = reader.result;
                output.style.display = 'block';
            };
            reader.readAsDataURL(event.target.files[0]);
        }

        // --- OTOMATİK SLUG OLUŞTURUCU ---
        const nameInput = document.getElementById('ProductName');
        const slugInput = document.getElementById('ProductSlug');

        nameInput.addEventListener('input', function() {
            // Eğer admin elle slug kısmına müdahale etmediyse otomatik doldur
            let text = nameInput.value;
            slugInput.value = generateSlug(text);
        });

        function generateSlug(text) {
            const trMap = {
                'ç': 'c', 'Ç': 'C', 'ğ': 'g', 'Ğ': 'G', 'ş': 's', 'Ş': 'S',
                'ü': 'u', 'Ü': 'U', 'ı': 'i', 'İ': 'I', 'ö': 'o', 'Ö': 'O'
            };
            for (let key in trMap) {
                text = text.replace(new RegExp(key, 'g'), trMap[key]);
            }
            return text.toLowerCase()
                .replace(/[^-a-zA-Z0-9\s]+/g, '') // Özel karakterleri sil
                .replace(/\s+/g, '-')             // Boşlukları - yap
                .replace(/-+/g, '-')              // Çift tireleri tek tire yap
                .trim();
        }
    </script>
}