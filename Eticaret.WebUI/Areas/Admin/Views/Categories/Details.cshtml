@model Eticaret.Core.Entities.Category

@{
    ViewData["Title"] = "Kategori Detayları";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card card-admin">
            <div class="card-header">
                <h5 class="card-title mb-0">Kategori Bilgileri</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted">Kategori Adı</dt>
                    <dd class="col-sm-9 fw-bold text-dark">@Model.Name</dd>

                    <dt class="col-sm-3 text-muted">Üst Kategori</dt>
                    <dd class="col-sm-9">@(Model.ParentId == 0 ? "Ana Kategori" : Model.ParentId.ToString())</dd>

                    <dt class="col-sm-3 text-muted">Sıra No</dt>
                    <dd class="col-sm-9">@Model.OrderNo</dd>

                    <dt class="col-sm-3 text-muted">Açıklama</dt>
                    <dd class="col-sm-9">@Model.Description</dd>

                    <dt class="col-sm-3 text-muted">Oluşturulma</dt>
                    <dd class="col-sm-9">@Model.CreateDate.ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="sticky-form-sidebar">
            <!-- Görsel -->
            <div class="card card-admin mb-4">
                <div class="card-header"><h5 class="card-title mb-0">Kategori Görseli</h5></div>
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.Image))
                    {
                        <img src="/img/categories/@Model.Image" alt="@Model.Name" class="img-fluid rounded shadow-sm" style="max-height: 200px;" />
                    }
                    else
                    {
                        <div class="text-muted py-4">
                            <i class="bi bi-image fs-1 d-block mb-2"></i>
                            Görsel Yok
                        </div>
                    }
                </div>
            </div>

            <!-- Durum ve İşlemler -->
            <div class="card card-admin">
                <div class="card-header"><h5 class="card-title mb-0">Durum</h5></div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-4">
                        <span>Aktiflik Durumu:</span>
                        @if (Model.isActive)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                    </div>
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary shadow-sm"><i class="bi bi-pencil-square me-2"></i> Düzenle</a>
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i> Listeye Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>