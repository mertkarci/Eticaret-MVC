@model IEnumerable<Eticaret.Core.Entities.Order>

@{
    ViewData["Title"] = "Sipariş Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark m-0">Siparişler</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm fw-medium">
        <i class="bi bi-plus-lg me-1"></i> Yeni Sipariş Oluştur
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-secondary">
                <tr>
                    <th class="ps-4 py-3">@Html.DisplayNameFor(model => model.OrderNumber)</th>
                    <th class="py-3">Müşteri</th>
                    <th class="py-3">@Html.DisplayNameFor(model => model.OrderDate)</th>
                    <th class="py-3">@Html.DisplayNameFor(model => model.TotalPrice)</th>
                    <th class="py-3">Durum</th>
                    <th class="pe-4 py-3 text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody class="border-top-0">
                @foreach (var item in Model) {
                    <tr>
                        <td class="ps-4 py-3 fw-bold text-dark">
                            #@Html.DisplayFor(modelItem => item.OrderNumber)
                        </td>
                        <td class="py-3">
                            <span class="fw-medium">@(item.AppUser?.Name ?? "Bilinmeyen Müşteri")</span>
                        </td>
                        <td class="py-3 text-muted">
                            @item.OrderDate.ToString("dd MMM yyyy HH:mm")
                        </td>
                        <td class="py-3 fw-bold text-success">
                            @item.TotalPrice.ToString("c")
                        </td>
                        <td class="py-3">
                            @switch (item.OrderState)
                            {
                                case Eticaret.Core.Entities.EnumOrderState.Waiting:
                                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Onay Bekliyor</span>
                                    break;
                                case Eticaret.Core.Entities.EnumOrderState.Approved:
                                    <span class="badge bg-info px-3 py-2 rounded-pill">Onaylandı</span>
                                    break;
                                case Eticaret.Core.Entities.EnumOrderState.Shipped:
                                    <span class="badge bg-primary px-3 py-2 rounded-pill">Kargoda</span>
                                    break;
                                case Eticaret.Core.Entities.EnumOrderState.Completed:
                                    <span class="badge bg-success px-3 py-2 rounded-pill">Tamamlandı</span>
                                    break;
                                case Eticaret.Core.Entities.EnumOrderState.Rejected:
                                    <span class="badge bg-danger px-3 py-2 rounded-pill">Reddedildi</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary px-3 py-2 rounded-pill">Belirsiz</span>
                                    break;
                            }
                        </td>
                        <td class="pe-4 py-3 text-end">
                            <div class="btn-group shadow-sm" role="group">
                                <a asp-action="Edit" class="btn btn-sm btn-outline-primary" asp-route-id="@item.Id" title="Düzenle">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="Details" class="btn btn-sm btn-outline-info" asp-route-id="@item.Id" title="Detaylar">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Delete" class="btn btn-sm btn-outline-danger" asp-route-id="@item.Id" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>