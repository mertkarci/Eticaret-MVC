@model IEnumerable<Eticaret.Core.Entities.Order>
@using Eticaret.WebUI.Extensions
@using System.Linq

@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="container py-4 py-md-5">
    <div class="row">
        <!-- SOL MENÜ (SIDEBAR) -->
        <div class="col-md-4 col-lg-3 mb-4 mb-md-0">
            <!-- Sol menüyü ekranda sabit tutan (Sticky) yapı -->
            <div class="position-sticky" style="top: 6rem; z-index: 10;">
                <div class="list-group shadow-sm border-0 rounded-3 overflow-hidden">
                    <a asp-action="Index" class="list-group-item list-group-item-action border-0 py-3">
                        <i class="bi bi-person me-2"></i> Üyelik Bilgileri
                    </a>
                    <!-- Bulunduğumuz sayfa "active" -->
                    <a asp-controller="Accounts" asp-action="MyOrders"
                        class="list-group-item list-group-item-action active border-0 py-3">
                        <i class="bi bi-bag-check me-2"></i> Siparişlerim
                    </a>
                    <a asp-controller="MyAddresses" asp-action="Index"
                        class="list-group-item list-group-item-action border-0 py-3">
                        <i class="bi bi-geo-alt me-2"></i> Adreslerim
                    </a>
                    <a href="/hesabim/cikis-yap"
                        class="list-group-item list-group-item-action text-danger border-0 py-3 d-none d-md-block">
                        <i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap
                    </a>
                </div>
            </div>
        </div>

        <!-- SAĞ İÇERİK (SİPARİŞLERİM KARTI) -->
        <div class="col-md-8 col-lg-9">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold text-dark">Siparişlerim</h5>
                </div>

                <!-- Kart Gövdesi -->
                <div class="card-body p-4 bg-gray-50/30">
                    @if (!Model.Any())
                    {
                        <!-- BOŞ DURUM (EMPTY STATE) -->
                        <div class="flex flex-col items-center justify-center py-10 px-4 text-center">
                            <div
                                class="w-16 h-16 rounded-full bg-gray-100 flex items-center justify-center mb-4 border border-gray-200 shadow-inner">
                                <i class="bi bi-bag-x text-3xl text-gray-400"></i>
                            </div>
                            <h3 class="text-lg font-semibold text-gray-900 mb-2">Henüz hiç siparişiniz bulunmuyor.</h3>
                            <p class="text-sm text-gray-500 mb-6 max-w-sm">Mağazamızdaki ürünleri keşfedin ve ilk
                                siparişinizi hemen oluşturun.</p>
                            <a asp-controller="Products" asp-action="Index"
                                class="inline-flex items-center justify-center px-6 py-2.5 bg-primary hover:bg-primary/90 text-white text-sm font-medium rounded-lg transition-all focus:outline-none shadow-sm">
                                Alışverişe Başla
                            </a>
                        </div>
                    }
                    else
                    {
                        <!-- Siparişler çok uzamasın diye içten kaydırmalı (scroll) kapsayıcı -->
                        <div class="space-y-4 pr-2"
                            style="max-height: 650px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: #cbd5e1 transparent;">
                            @foreach (var item in Model.OrderByDescending(x => x.OrderDate))
                            {
                                // Extension metodumuz
                                var ui = item.OrderState.GetStatusUI();

                                <!-- İç Sipariş Kartı (Modern Görünüm) -->
                                <div
                                    class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow duration-300">

                                    <!-- Üst Bilgi Barı -->
                                    <div class="bg-gray-50/80 border-b border-gray-200 px-4 py-3 sm:px-5">
                                        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                                            <div class="flex flex-wrap items-center gap-6">
                                                <div>
                                                    <p
                                                        class="text-[11px] font-bold text-gray-500 uppercase tracking-wider mb-0.5">
                                                        Sipariş Tarihi</p>
                                                    <p class="text-sm font-semibold text-gray-900 mb-0">
                                                        @item.OrderDate.ToString("dd MMMM yyyy")</p>
                                                </div>
                                                <div>
                                                    <p
                                                        class="text-[11px] font-bold text-gray-500 uppercase tracking-wider mb-0.5">
                                                        Toplam Tutar</p>
                                                    <p class="text-sm font-bold text-primary mb-0">
                                                        @item.TotalPrice.ToString("c")</p>
                                                </div>
                                                <div class="hidden sm:block">
                                                    <p
                                                        class="text-[11px] font-bold text-gray-500 uppercase tracking-wider mb-0.5">
                                                        Ürün Sayısı</p>
                                                    <p class="text-sm font-semibold text-gray-900 mb-0">@item.OrderLines.Count
                                                        Adet</p>
                                                </div>
                                            </div>
                                            <div class="sm:text-right">
                                                <p class="text-[11px] font-bold text-gray-500 uppercase tracking-wider mb-0.5">
                                                    Sipariş No</p>
                                                <p class="text-sm font-mono font-bold text-gray-900 mb-0">#@item.OrderNumber</p>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Alt Ürün ve İşlem Barı -->
                                    <div
                                        class="px-4 py-4 sm:px-5 flex flex-col lg:flex-row gap-5 items-start lg:items-center justify-between">

                                        <!-- Ürünler (Avatar Group & İsim) -->
                                        <div class="flex items-center gap-4 w-full lg:flex-1 min-w-0">
                                            <div class="flex -space-x-3 overflow-hidden p-1">
                                                @foreach (var line in item.OrderLines.Take(2))
                                                {
                                                    <div
                                                        class="inline-block w-12 h-12 sm:w-14 sm:h-14 rounded-lg border-2 border-white bg-gray-50 shadow-sm overflow-hidden flex-shrink-0 relative group">
                                                        <img src="~/img/products/@line.Product.Image"
                                                            class="w-full h-full object-contain mix-blend-multiply group-hover:scale-110 transition-transform duration-300 p-1"
                                                            alt="@line.Product.Name" title="@line.Product.Name">
                                                    </div>
                                                }
                                                @if (item.OrderLines.Count > 2)
                                                {
                                                    <div class="inline-flex w-12 h-12 sm:w-14 sm:h-14 items-center justify-center rounded-lg border-2 border-white bg-gray-100 text-xs font-bold text-gray-600 shadow-sm relative z-10"
                                                        title="Diğer ürünler">
                                                        +@(item.OrderLines.Count - 2)
                                                    </div>
                                                }
                                            </div>

                                            <!-- İsim Özeti -->
                                            <div class="flex-1 min-w-0">
                                                @if (item.OrderLines.Any())
                                                {
                                                    var firstProduct = item.OrderLines.First().Product;
                                                    <p class="text-sm font-semibold text-gray-900 truncate mb-0.5"
                                                        title="@firstProduct.Name">@firstProduct.Name</p>
                                                    @if (item.OrderLines.Count > 1)
                                                    {
                                                        <p class="text-xs text-gray-500 mb-0">ve @(item.OrderLines.Count - 1) ürün daha
                                                            siparişte.</p>
                                                    }
                                                }
                                            </div>
                                        </div>

                                        <!-- Durum & Buton -->
                                        <div
                                            class="flex flex-col sm:flex-row lg:flex-col xl:flex-row items-center gap-3 w-full lg:w-auto pt-3 lg:pt-0 border-t border-gray-100 lg:border-t-0 flex-shrink-0">
                                            <span
                                                class="inline-flex items-center justify-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold shadow-sm w-full sm:w-auto @ui.BadgeClass">
                                                <i class="bi bi-@ui.Icon"></i> @Html.DisplayFor(modelItem => item.OrderState)
                                            </span>

                                            <a asp-action="MyOrderDetails" asp-controller="Accounts"
                                                asp-route-orderNumber="@item.OrderNumber"
                                                class="inline-flex items-center justify-center gap-2 px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium bg-white text-gray-700 hover:bg-gray-50 hover:text-primary transition-all w-full sm:w-auto shadow-sm focus:outline-none">
                                                Siparişi İncele <i class="bi bi-chevron-right text-[10px]"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Mobil Çıkış Yap Butonu -->
            <div class="d-md-none mt-4">
                <a href="/hesabim/cikis-yap" class="btn btn-outline-danger w-100 rounded-pill shadow-sm">
                    <i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap
                </a>
            </div>
        </div>
    </div>
</div>