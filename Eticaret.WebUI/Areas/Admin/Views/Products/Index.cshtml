@model IEnumerable<Eticaret.Core.Entities.Product>

@{
    ViewData["Title"] = "Ürünler";
}
<style>
    td.fixed-height {
        max-width: 180px;
        height: 22px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    #datatablesSimple tbody tr td:last-child {
        white-space: nowrap;
</style>
<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Create" class="btn btn-create shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Yeni Ürün Ekle
    </a>
</div>
<table class="table table-striped table-hover" id="datatablesSimple">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Stock)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Category)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Brand)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductCode)
            </th>

            <th>
                @Html.DisplayNameFor(model => model.Image)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.isActive)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.isHome)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Stock)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Category.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Brand.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Price)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ProductCode)
                </td>
                <td>
                    <a href="/img/products/@Html.DisplayFor(modelItem => item.Image)">
                        <img src="/img/products/@Html.DisplayFor(modelItem => item.Image)" height="100"></a>

                    <a href="/Admin/ProductImages/Create?ProductId=@Html.DisplayFor(modelItem => item.Id)" target="_blank"
                        title="Yeni Resim Ekle" class="ms-2"><i class="fa-solid fa-plus"></i></a>
                    <a href="/Admin/ProductImages/Index?ProductId=@Html.DisplayFor(modelItem => item.Id)" target="_blank"
                        title="Ürün Resimleri" class="ms-2"><i class="fa-solid fa-plus"></i></a>
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.isActive)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.isHome)
                </td>
                <td>
                    <a asp-action="Edit" class="btn btn-sm btn-primary" asp-route-id="@item.Id">Düzenle</a>
                    <a asp-action="Details" class="btn btn-sm btn-info" asp-route-id="@item.Id">Detaylar</a>
                    <a asp-action="Delete" class="btn btn-sm btn-danger" asp-route-id="@item.Id">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<script src="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/umd/simple-datatables.min.js"
    crossorigin="anonymous"></script>
<script src="/admin/js/datatables-simple-demo.js"></script>