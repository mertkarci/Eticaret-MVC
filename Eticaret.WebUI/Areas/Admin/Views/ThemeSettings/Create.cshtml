@model Eticaret.Core.Entities.ThemeSetting

@{
    ViewData["Title"] = "Yeni Tema Oluştur";
}

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card card-admin">
                <div class="card-header"><h5 class="card-title mb-0">Tema Bilgileri</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control form-control-lg" placeholder="Örn: Yaz Teması" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="card card-admin mt-4">
                <div class="card-header"><h5 class="card-title mb-0">Renk Paleti</h5></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6 col-lg-4">
                            <label asp-for="MainColor" class="form-label">Ana Renk</label>
                            <input asp-for="MainColor" type="color" class="form-control form-control-color w-100" />
                        </div>
                        <div class="col-md-6 col-lg-4">
                            <label asp-for="SecondaryColor" class="form-label">İkincil Renk</label>
                            <input asp-for="SecondaryColor" type="color" class="form-control form-control-color w-100" />
                        </div>
                        <div class="col-md-6 col-lg-4">
                            <label asp-for="BackgroundColor" class="form-label">Arkaplan</label>
                            <input asp-for="BackgroundColor" type="color" class="form-control form-control-color w-100" />
                        </div>
                        <div class="col-md-6 col-lg-4">
                            <label asp-for="TextColor" class="form-label">Metin Rengi</label>
                            <input asp-for="TextColor" type="color" class="form-control form-control-color w-100" />
                        </div>
                        <div class="col-md-6 col-lg-4">
                            <label asp-for="NavbarBgColor" class="form-label">Menü Arkaplan</label>
                            <input asp-for="NavbarBgColor" type="color" class="form-control form-control-color w-100" />
                        </div>
                        <div class="col-md-6 col-lg-4">
                            <label asp-for="FooterBgColor" class="form-label">Alt Bilgi Arkaplan</label>
                            <input asp-for="FooterBgColor" type="color" class="form-control form-control-color w-100" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="sticky-form-sidebar">
                <div class="card card-admin">
                    <div class="card-header"><h5 class="card-title mb-0">Kaydet</h5></div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-submit shadow-sm">
                                <i class="bi bi-palette me-2"></i> Temayı Oluştur
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-2"></i> İptal
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card card-admin mt-4">
                    <div class="card-header"><h5 class="card-title mb-0">Durum</h5></div>
                    <div class="card-body">
                        <div class="form-check form-switch">
                            <input class="form-check-input" asp-for="IsActive" />
                            <label class="form-check-label" asp-for="IsActive">Varsayılan Yap</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }