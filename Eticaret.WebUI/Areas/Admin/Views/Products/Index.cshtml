@model IEnumerable<Eticaret.Core.Entities.Product>

@{
    ViewData["Title"] = "Ürünler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Create" class="btn btn-create shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Yeni Ürün Ekle
    </a>
</div>

<div class="card card-admin">
    <div class="card-body">
        <table id="datatablesSimple" class="table-admin table-hover">
            <thead>
                <tr>
                    <th class="ps-4">Görsel</th>
                    <th>@Html.DisplayNameFor(model => model.Name)</th>
                    <th>@Html.DisplayNameFor(model => model.Category)</th>
                    <th>@Html.DisplayNameFor(model => model.Brand)</th>
                    <th>@Html.DisplayNameFor(model => model.Price)</th>
                    <th>@Html.DisplayNameFor(model => model.Stock)</th>
                    <th>@Html.DisplayNameFor(model => model.isActive)</th>
                    <th>@Html.DisplayNameFor(model => model.isHome)</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(item.Image))
                                {
                                    <img src="/img/products/@item.Image" alt="@item.Name" class="rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover;" />
                                }
                                else
                                {
                                    <span class="text-muted small">Resim Yok</span>
                                }
                                <div class="d-flex flex-column gap-1">
                                    <a href="/Admin/ProductImages/Create?ProductId=@item.Id" target="_blank" class="btn btn-sm btn-light border shadow-sm py-0 px-1" title="Resim Ekle">
                                        <i class="bi bi-plus-lg text-primary" style="font-size: 0.8rem;"></i>
                                    </a>
                                    <a href="/Admin/ProductImages/Index?ProductId=@item.Id" target="_blank" class="btn btn-sm btn-light border shadow-sm py-0 px-1" title="Galeri">
                                        <i class="bi bi-images text-secondary" style="font-size: 0.8rem;"></i>
                                    </a>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="fw-bold text-dark">@Html.DisplayFor(modelItem => item.Name)</div>
                            <small class="text-muted">@Html.DisplayFor(modelItem => item.ProductCode)</small>
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.Category.Name)</td>
                        <td>@Html.DisplayFor(modelItem => item.Brand.Name)</td>
                        <td class="fw-bold text-primary">@item.Price.ToString("c")</td>
                        <td>
                            @if (item.Stock < 10)
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1">@item.Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark border px-2 py-1">@item.Stock</span>
                            }
                        </td>
                        <td>
                            @if (item.isActive)
                            {
                                <span class="badge bg-success rounded-pill px-3 py-2">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-50 rounded-pill px-3 py-2">Pasif</span>
                            }
                        </td>
                        <td>
                            @if (item.isHome)
                            {
                                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                            }
                            else
                            {
                                <i class="bi bi-circle text-muted fs-5"></i>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <div class="action-buttons">
                                <a asp-action="Edit" class="btn btn-outline-primary" asp-route-id="@item.Id" title="Düzenle">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="Details" class="btn btn-outline-info" asp-route-id="@item.Id" title="Detaylar">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Delete" class="btn btn-outline-danger" asp-route-id="@item.Id" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>