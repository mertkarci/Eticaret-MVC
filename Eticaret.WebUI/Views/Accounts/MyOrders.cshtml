@model IEnumerable<Eticaret.Core.Entities.Order>

@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="container py-5">
    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-box-seam fs-3 text-primary me-2"></i>
        <h2 class="fw-bold m-0">Siparişlerim</h2>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-light rounded-4 border border-dashed">
            <i class="bi bi-bag-x display-1 text-muted opacity-50"></i>
            <h4 class="mt-3 text-muted">Henüz hiç siparişiniz bulunmuyor.</h4>
            <a href="/Products" class="btn btn-primary mt-3 rounded-pill px-4">Alışverişe Başla</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model.OrderByDescending(x => x.OrderDate))
            {
                // Sipariş durumuna göre renk belirleme
                string badgeClass = "bg-secondary bg-opacity-10 text-secondary border-secondary";
                string statusIcon = "circle";

                var statusStr = item.OrderState.ToString();

                if (statusStr == "Waiting")
                {
                    badgeClass = "bg-warning bg-opacity-90 mytext border-warning";
                    statusIcon = "hourglass-split";
                }
                else if (statusStr == "Shipped")
                {
                    badgeClass = "bg-info bg-opacity-90 mytext border-info";
                    statusIcon = "truck";
                }
                else if (statusStr == "Approved")
                {
                    badgeClass = "bg-myapproved mytext border-info";
                    statusIcon = "box2-fill";
                }
                else if (statusStr == "Completed")
                {
                    badgeClass = "bg-success bg-opacity-20 mytext border-success";
                    statusIcon = "check-circle-fill";
                }
                else if (statusStr == "Rejected")
                {
                    badgeClass = "bg-danger bg-opacity-20 mytext mytext border-danger";
                    statusIcon = "x-circle-fill";
                }

                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                        <div class="card-header mycard border-bottom-0 p-3 p-md-4">
                            <div class="row align-items-center g-3">
                                <div class="col-6 col-md-3">
                                    <small class="mytext d-block mb-1">Sipariş Tarihi</small>
                                    <span class="fw-medium mytext">@item.OrderDate.ToString("dd MMMM yyyy HH:mm")</span>
                                </div>
                                <div class="col-6 col-md-3">
                                    <small class="mytext d-block mb-1">Sipariş Özeti</small>
                                    <span class="fw-medium mytext">@item.OrderLines.Count Ürün</span>
                                </div>
                                <div class="col-6 col-md-3">
                                    <small class="mytext d-block mb-1">Toplam Tutar</small>
                                    <span class="fw-bold mytext fs-5">@item.TotalPrice.ToString("c")</span>
                                </div>
                                <div class="col-6 col-md-3 text-md-end">
                                    <span class="badge @badgeClass border px-3 py-2 rounded-pill">
                                        <i class="bi  bi-@statusIcon me-1"></i> @Html.DisplayFor(modelItem => item.OrderState)
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Kart İçeriği: Ürünler -->
                        <div class="card-body p-3">
                            @foreach (var line in item.OrderLines.Take(2))
                            {
                                <div
                                    class="d-flex align-items-center @(item.OrderLines.Take(2).Last() != line ? "mb-3 pb-3 border-bottom" : "")">
                                    <div class="flex-shrink-0 border rounded-3 p-1 bg-white" style="width: 50px; height: 50px;">
                                        <img src="~/img/products/@line.Product.Image" class="w-100 h-100 object-fit-cover rounded-2"
                                            alt="@line.Product.Name">
                                    </div>
                                    <div class="ms-3 flex-grow-1">
                                        <h6 class="mb-0 fw-semibold text-dark small text-truncate" style="max-width: 250px;">
                                            <a href="/Products/Details/@line.Product.Id" class="text-decoration-none text-dark">
                                                @line.Product.Name
                                            </a>
                                        </h6>
                                        <small class="text-muted">@line.Quantity adet x @line.UnitPrice.ToString("c")</small>
                                    </div>
                                    <div class="fw-bold text-dark small">@((line.UnitPrice * line.Quantity).ToString("c"))</div>
                                </div>
                            }

                            @if (item.OrderLines.Count > 2)
                            {
                                <div class="text-center mt-3">
                                    <small class="text-muted fw-medium">... ve @(item.OrderLines.Count - 2) ürün daha</small>
                                </div>
                            }
                        </div>

                        <!-- Kart Altı: Detay Butonu ve Sipariş No -->
                        <div class="card-footer mycard p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="mytext mycardfont-monospace">Sipariş No: #@item.OrderNumber</small>
                                <a href="/Accounts/MyOrderDetails/@item.Id"
                                    class="btn btn-sm btn-primary btn-primary-order  rounded-pill px-3">
                                    Detayları Görüntüle <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .last-border-none:last-child {
        border-bottom: none !important;
    }

    .object-fit-cover {
        object-fit: cover;
    }
</style>