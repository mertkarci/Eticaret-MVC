@{
    ViewData["Title"] = "Siparişiniz Alındı";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <div class="mb-4">
                    <i class="bi bi-bag-check-fill text-success" style="font-size: 5rem;"></i>
                </div>
                <h1 class="display-5 fw-bold">Teşekkürler!</h1>
                <p class="lead text-muted">Siparişiniz başarıyla alınmıştır.</p>

                @if (TempData["OrderNumber"] != null)
                {
                    <p class="fs-5 mt-4">Sipariş Numaranız: <strong class="text-primary">@TempData["OrderNumber"]</strong></p>
                }
                else if (ViewBag.OrderNumber != null)
                {
                    <p class="fs-5 mt-4">Sipariş Numaranız: <strong class="text-primary">@ViewBag.OrderNumber</strong></p>
                }

                <div class="d-flex gap-2 justify-content-center mt-4">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-action="MyOrders" asp-controller="Accounts" class="btn btn-primary rounded-pill px-4">Siparişlerim</a>
                    }
                    <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary rounded-pill px-4">Alışverişe Devam Et</a>
                </div>
            </div>
        </div>
    </div>
</section>