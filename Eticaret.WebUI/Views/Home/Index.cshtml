@model HomePageViewModel
@{
    ViewData["Title"] = "Ana Sayfa";
    ViewData["ShowCart"] = true; // BU SATIR BUTONU AÇAR!
}

<!-- Slider Alanı -->
<section class="mb-5">
    <div class="container">
        <div class="shadow-sm rounded-4 overflow-hidden">
            <partial name="_Slider" model="Model.Sliders" />
        </div>
    </div>
</section>

<!-- Popüler Ürünler -->
<section class="py-5">
    <div class="container">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold m-0">Öne Çıkan Ürünler</h2>
            <a href="/Products" class="btn btn-outline-primary rounded-pill px-4">
                Tümünü Gör <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
        
        <div class="row gx-4 gx-lg-5 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
            @if (Model.Products != null && Model.Products.Any())
            {
                @foreach (var item in Model.Products)
                {
                    <partial name="_ProductView" model="item" />
                }
            }
        </div>
    </div>
</section>

<!-- Kampanyalar / Haberler -->
<section class="py-5 bg-light bg-opacity-25">
    <div class="container">
        <h2 class="fw-bold mb-4">Kampanyalar & Duyurular</h2>
        <div class="row gx-4 gx-lg-5 row-cols-1 row-cols-md-2 justify-content-center">
            @if (Model.News != null && Model.News.Any())
            {
                @foreach (var item in Model.News)
                {
                    <partial name="_NewsView" model="item" />
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <div class="alert alert-light border shadow-sm">
                        Henüz aktif bir kampanya bulunmuyor.
                    </div>
                </div>
            }
        </div>
    </div>
</section>