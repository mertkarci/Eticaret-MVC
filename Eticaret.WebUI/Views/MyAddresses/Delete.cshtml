@model Eticaret.Core.Entities.Address

@{
    ViewData["Title"] = "Adresil Sil";
}

<div class="container py-4 py-md-5">
    <div class="row justify-content-center align-items-center" style="min-height: 75vh;">
        <div class="col-12 col-md-10 col-lg-8">
            <div class=" shadow-sm p-4 p-md-4" style="border-radius: 3rem;">
                <div class="d-flex align-items-center mb-3 mb-md-3">
                    <a href="@Url.Action("Index")"
                        class="btn btn-outline-secondary rounded-circle me-3 d-flex align-items-center justify-content-center flex-shrink-0"
                        style="width: 40px; height: 40px;">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <div>
                        <h2 class="fw-bold text-dark mb-0 fs-3 fs-md-2">Adresi Sil</h2>
                        <p class="text-muted small mb-0">Bu işlemi geri alamazsınız.</p>
                    </div>
                </div>

                <div class="card border-0 bg-light rounded-4 mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-white p-3 rounded-circle shadow-sm me-3 text-danger">
                                <i class="bi bi-geo-alt-fill fs-4"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold text-dark mb-0">@Model.Title</h5>
                                <small class="text-muted">@Model.City / @Model.District</small>
                            </div>
                        </div>

                        <p class="text-secondary mb-0">@Model.OpenAddress</p>

                        <div class="mt-3 pt-3 border-top border-white">
                            <div class="d-flex gap-2">
                                @if (Model.IsDeliveryAddress)
                                {
                                    <span class="badge bg-white text-secondary border fw-normal"><i
                                            class="bi bi-truck me-1"></i> Teslimat</span>
                                }
                                @if (Model.IsBillingAddress)
                                {
                                    <span class="badge bg-white text-secondary border fw-normal"><i
                                            class="bi bi-receipt me-1"></i> Fatura</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-warning d-flex align-items-center rounded-4 mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
                    <div>
                        <strong>Emin misiniz?</strong><br>
                        "@Model.Title" başlıklı adresiniz kalıcı olarak silinecektir.
                    </div>
                </div>

                <form asp-action="Delete" asp-route-name="@Model.Title" method="post">
                <input type="hidden" name="id" value="@Model.AddressGuid" />
                    <div class="d-flex flex-column flex-md-row justify-content-end gap-2">
                        <a asp-action="Index"
                            class="btn btn-outline-secondary rounded-pill px-4 w-100 w-md-auto order-1 order-md-0 text-nowrap">İptal</a>
                        <button type="submit"
                            class="btn btn-danger rounded-pill px-4 w-100 w-md-auto order-0 order-md-1 text-nowrap">
                            <i class="bi bi-trash-fill me-1"></i> Evet, Sil
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>