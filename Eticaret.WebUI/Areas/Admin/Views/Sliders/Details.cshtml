@model Eticaret.Core.Entities.Slider

@{
    ViewData["Title"] = "Slider Detayları";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card card-admin mb-4">
            <div class="card-header"><h5 class="card-title mb-0">Slider Görseli</h5></div>
            <div class="card-body p-0">
                @if (!string.IsNullOrEmpty(Model.Image))
                {
                    <img src="/img/sliders/@Model.Image" alt="@Model.Title" class="img-fluid w-100" style="max-height: 400px; object-fit: cover;" />
                }
                else
                {
                    <div class="text-center py-5 text-muted">Görsel Yok</div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="sticky-form-sidebar">
            <div class="card card-admin">
                <div class="card-header"><h5 class="card-title mb-0">İçerik Bilgileri</h5></div>
                <div class="card-body">
                    <dl class="row mb-4">
                        <dt class="col-sm-4 text-muted">Başlık</dt>
                        <dd class="col-sm-8 fw-bold">@Model.Title</dd>

                        <dt class="col-sm-4 text-muted">Açıklama</dt>
                        <dd class="col-sm-8">@Model.Description</dd>

                        <dt class="col-sm-4 text-muted">Link</dt>
                        <dd class="col-sm-8 text-truncate">
                            <a href="@Model.Link" target="_blank">@Model.Link</a>
                        </dd>
                    </dl>
                    
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary shadow-sm"><i class="bi bi-pencil-square me-2"></i> Düzenle</a>
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i> Listeye Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>