@model IEnumerable<Eticaret.Core.Entities.ProductImage>

@{
    ViewData["Title"] = "Ürün Görselleri";
}
<style>
    td.fixed-height {
        max-width: 180px;
        height: 22px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    #datatablesSimple tbody tr td:last-child {
        white-space: nowrap;
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <a asp-action="Create" class="btn btn-create shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Yeni Görsel Ekle
    </a>
</div>
<table class="table table-striped table-hover" id="datatablesSimple">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Alt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Product)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <img src="/img/products/@Html.DisplayFor(modelItem => item.Name)" height="100">
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Alt)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Product.Id)
                </td>
                <td>
                    <a asp-action="Edit" class="btn btn-sm btn-primary" asp-route-id="@item.Id">Düzenle</a>
                    <a asp-action="Details" class="btn btn-sm btn-info" asp-route-id="@item.Id">Detaylar</a>
                    <a asp-action="Delete" class="btn btn-sm btn-danger" asp-route-id="@item.Id">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<script src="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/umd/simple-datatables.min.js"
    crossorigin="anonymous"></script>
<script src="/admin/js/datatables-simple-demo.js"></script>