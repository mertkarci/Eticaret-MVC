@model HomePageViewModel
@{
    ViewData["Title"] = "Ana Sayfa";
    ViewData["ShowCart"] = true; // BU SATIR BUTONU AÇAR!
}

<!-- Slider Alanı -->
<section class="mb-8 md:mb-12">
    <div class="container mx-auto px-4">
        <div class="shadow-lg rounded-xl overflow-hidden">
            <partial name="_Slider" model="Model.Sliders" />
        </div>
    </div>
</section>

<!-- Popüler Ürünler -->
<section class="py-8 md:py-12">
    <div class="container mx-auto px-4">

        <div class="flex justify-between items-center mb-6 md:mb-8">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white m-0">Öne Çıkan Ürünler</h2>
            <a asp-controller="Products" asp-action="Index" title="Tümünü Gör"
               class="inline-flex items-center gap-2 rounded-lg border border-primary px-4 py-2 text-sm font-semibold text-primary hover:bg-primary/10 focus:outline-none focus:ring-2 focus:ring-primary/50 transition-colors no-underline">
                Tümünü Gör <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-6">
            @if (Model.Products != null && Model.Products.Any())
            {
                @foreach (var item in Model.Products)
                {
                    <!-- _ProductView partial'ı da Tailwind'e çevrilmeli -->
                    <partial name="_ProductView" model="item" />
                }
            }
        </div>
    </div>
</section>

<!-- Kampanyalar / Haberler -->
<section class="py-12 md:py-16 bg-gray-50 dark:bg-slate-800/50">
    <div class="container mx-auto px-4">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white text-center mb-8">Kampanyalar & Duyurular</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
            @if (Model.News != null && Model.News.Any())
            {
                @foreach (var item in Model.News)
                {
                    <!-- _NewsView partial'ı da Tailwind'e çevrilmeli -->
                    <partial name="_NewsView" model="item" />
                }
            }
            else
            {
                <div class="md:col-span-2 text-center">
                    <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-lg p-6">
                        Henüz aktif bir kampanya bulunmuyor.
                    </div>
                </div>
            }
        </div>
    </div>
</section>