@model Eticaret.Core.Entities.ProductImage

@{
    ViewData["Title"] = "Ürün Görseli Düzenle";
}

<form asp-action="Edit" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="Name" />

    <div class="row g-4">
        <!-- SOL KOLON: Ana İçerik -->
        <div class="col-lg-8">
            <!-- Görsel Yükleme -->
            <div class="card card-admin">
                <div class="card-header"><h5 class="card-title mb-0">Görsel</h5></div>
                <div class="card-body">
                    <label for="file-upload" class="custom-file-upload-container">
                        <div class="icon"><i class="bi bi-cloud-arrow-up-fill"></i></div>
                        <div class="text">
                            <span>Görseli değiştirmek için tıklayın</span>
                        </div>
                        <input id="file-upload" name="Image" type="file" onchange="previewImage(event)" />
                    </label>

                    <div class="mt-3 text-center">
                        <img id="image-preview" src="@(string.IsNullOrEmpty(Model.Name) ? "" : "/img/products/" + Model.Name)"
                             alt="Görsel Önizleme"
                             style="max-width: 100%; max-height: 300px; border-radius: 0.5rem; display: @(string.IsNullOrEmpty(Model.Name) ? "none" : "inline-block");" />
                    </div>
                </div>
            </div>

            <!-- Görsel Bilgileri (Alt) -->
            <div class="card card-admin mt-4">
                <div class="card-header"><h5 class="card-title mb-0">Görsel Bilgileri</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Alt" class="form-label"></label>
                        <input asp-for="Alt" class="form-control" />
                        <span asp-validation-for="Alt" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- İlişkili Ürün -->
            <div class="card card-admin mt-4">
                <div class="card-header"><h5 class="card-title mb-0">İlişkili Ürün</h5></div>
                <div class="card-body">
                    <label asp-for="ProductId" class="form-label"></label>
                    <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductId">
                        <option value="">Ürün Seçiniz</option>
                    </select>
                    <span asp-validation-for="ProductId" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <!-- SAĞ KOLON: Eylemler ve Durum -->
        <div class="col-lg-4">
            <div class="sticky-form-sidebar">
                <!-- Eylemler -->
                <div class="card card-admin">
                    <div class="card-header"><h5 class="card-title mb-0">Eylemler</h5></div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-submit shadow-sm">
                                <i class="bi bi-check-circle me-2"></i> Değişiklikleri Kaydet
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-2"></i> İptal
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>function previewImage(e){const r=new FileReader;r.onload=function(){const o=document.getElementById("image-preview");o.src=r.result,o.style.display="inline-block"},r.readAsDataURL(e.target.files[0])}</script>
}