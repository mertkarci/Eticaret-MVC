@model Eticaret.WebUI.Areas.Admin.Models.UserDetailsViewModel
@using Eticaret.WebUI.Extensions
@{
    ViewData["Title"] = "Kullanıcı Detayları";
}
<style href="site.css"></style>
<div class="row g-4">
    <div class="col-lg-8">
        <ul class="nav nav-tabs mb-4" id="userTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold" id="general-tab" data-bs-toggle="tab"
                    data-bs-target="#general-pane" type="button" role="tab" aria-selected="true">
                    <i class="bi bi-person me-1"></i> Genel Bilgiler
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="addresses-tab" data-bs-toggle="tab"
                    data-bs-target="#addresses-pane" type="button" role="tab" aria-selected="false">
                    <i class="bi bi-geo-alt me-1"></i> Adresler
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders-pane"
                    type="button" role="tab" aria-selected="false">
                    <i class="bi bi-box-seam me-1"></i> Siparişler
                </button>
            </li>
        </ul>

        <div class="tab-content" id="userTabsContent">
            <div class="tab-pane fade show active" id="general-pane" role="tabpanel" tabindex="0">
                <div class="card card-admin border-top-0 rounded-top-0">
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-3 text-muted">Ad Soyad</dt>
                            <dd class="col-sm-9 fw-bold text-dark">@Model.User.Name @Model.User.Surname</dd>
                            <dt class="col-sm-3 text-muted">Kullanıcı Adı</dt>
                            <dd class="col-sm-9">@Model.User.Username</dd>
                            <dt class="col-sm-3 text-muted">E-Posta</dt>
                            <dd class="col-sm-9"><a href="mailto:@Model.User.Email"
                                    class="text-decoration-none">@Model.User.Email</a></dd>
                            <dt class="col-sm-3 text-muted">Telefon</dt>
                            <dd class="col-sm-9"><a href="tel:@Model.User.Phone"
                                    class="text-decoration-none">@Model.User.Phone</a></dd>
                            <dt class="col-sm-3 text-muted">Kayıt Tarihi</dt>
                            <dd class="col-sm-9">@Model.User.CreateDate.ToString("dd.MM.yyyy HH:mm")</dd>
                            <dt class="col-sm-3 text-muted">User Guid</dt>
                            <dd class="col-sm-9 text-muted small font-monospace">@Model.User.UserGuid</dd>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="addresses-pane" role="tabpanel" tabindex="0">
                <div class="card card-admin border-top-0 rounded-top-0">
                    <div class="card-body">
                        <h6 class="text-muted mb-3">Kayıtlı Adresler</h6>
                        @if (Model.Addresses != null && Model.Addresses.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var address in Model.Addresses)
                                {
                                    <li class="list-group-item px-0">
                                        <div class="fw-bold text-dark">@address.Title</div>
                                        <div>@address.City / @address.District</div>
                                        <div class="text-muted small">@address.OpenAddress</div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="alert alert-warning mb-0">Bu kullanıcıya ait kayıtlı adres bulunamadı.</div>
                        }
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="orders-pane" role="tabpanel" tabindex="0">
                <div class="card card-admin border-top-0 rounded-top-0">
                    <div class="card-body">
                        <h6 class="text-muted mb-3">Sipariş Geçmişi</h6>
                        @if (Model.Orders != null && Model.Orders.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0 align-middle">
                                    <thead>
                                        <tr>
                                            <th>Sipariş No</th>
                                            <th>Tarih</th>
                                            <th>Durum</th>
                                            <th class="text-end">İşlem</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var order in Model.Orders)
                                        {
                                            var ui = order.OrderState.GetStatusUI();
                                            <tr>
                                                <td class="fw-bold">@order.OrderNumber</td>
                                                <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                                                <td>
                                                    <span class="badge @ui.BadgeClass border">
                                                        <i class="bi bi-@ui.Icon me-1"></i> @Html.DisplayFor(m =>
                                                                                                        order.OrderState) </span>
                                        </td>
                                        <td class="text-end">
                                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id"
                                                class="btn btn-sm btn-outline-primary">Detay</a>
                                        </td>
                                    </tr>
                                                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning mb-0">Bu kullanıcının henüz siparişi bulunmuyor.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="sticky-form-sidebar">
            <div class="card card-admin">
                <div class="card-header">
                    <h5 class="card-title mb-0">Yetki ve Durum</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                        <span>Rol:</span>
                        @if (Model.User.isAdmin)
                        {
                            <span class="badge bg-danger">Yönetici</span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark">Kullanıcı</span>
                        }
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span>Durum:</span>
                        @if (Model.User.isActive)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                    </div>
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.User.Id" class="btn btn-primary shadow-sm"><i
                                class="bi bi-pencil-square me-2"></i> Düzenle</a>
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>
                            Listeye Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>