@model IEnumerable<Eticaret.WebUI.Areas.Admin.Models.AppLog>
@{
    ViewData["Title"] = "Sistem Logları";
}

<!-- Tailwind CSS CDN ve Ayarları (Bootstrap Çakışmasını Önlemek İçin) -->
<script src="https://cdn.tailwindcss.com"></script>
<script>
    tailwind.config = {
        corePlugins: {
            preflight: false,
        }
    }
</script>

<div class="bg-white shadow-sm rounded-xl border border-gray-200 overflow-hidden">
    <!-- Üst Bar ve Filtreler -->
    <div class="bg-gray-50/50 border-b border-gray-200 px-6 py-4 flex flex-col md:flex-row justify-between items-center gap-4">
        <h5 class="text-lg font-semibold text-gray-800 m-0">Sistem Logları</h5>
        
        <form method="get" class="flex flex-wrap items-center gap-3 w-full md:w-auto">
            <div class="relative w-full md:w-64">
                <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                    <i class="bi bi-search text-gray-400 text-sm"></i>
                </div>
                <input type="text" name="search" class="pl-9 pr-4 py-2 border border-gray-300 rounded-lg text-sm w-full focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm" placeholder="İşlem veya mesaj ara..." value="@ViewBag.CurrentSearch">
            </div>
            
            <select name="level" class="border border-gray-300 rounded-lg px-4 py-2 text-sm bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all cursor-pointer shadow-sm">
                <option value="">Tüm Seviyeler</option>
                <option value="Information" selected="@(ViewBag.CurrentLevel == "Information")">Bilgi (Info)</option>
                <option value="Warning" selected="@(ViewBag.CurrentLevel == "Warning")">Uyarı (Warning)</option>
                <option value="Error" selected="@(ViewBag.CurrentLevel == "Error")">Hata (Error)</option>
                <option value="Fatal" selected="@(ViewBag.CurrentLevel == "Fatal")">Kritik (Fatal)</option>
            </select>
            
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm whitespace-nowrap">
                Filtrele
            </button>
        </form>
    </div>
    
    <!-- Tablo -->
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left text-gray-600">
            <thead class="text-xs text-gray-500 uppercase bg-gray-50 border-b border-gray-200">
                    <tr>
                    <th scope="col" class="px-6 py-4 font-medium" style="width: 200px;">Tarih</th>
                    <th scope="col" class="px-6 py-4 font-medium" style="width: 140px;">Seviye</th>
                    <th scope="col" class="px-6 py-4 font-medium">İşlem / Mesaj</th>
                    </tr>
                </thead>
            <tbody class="divide-y divide-gray-100">
                    @foreach (var log in Model)
                    {
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex items-center text-gray-500 font-medium">
                                <i class="bi bi-clock me-2 opacity-70"></i>
                                @{
                                    DateTime dt;
                                    // Veritabanından gelen UTC saati güvenli şekilde ayrıştırıp, Türkiye saatine (+3) dönüştürüyoruz
                                    if (DateTime.TryParse(log.Timestamp, null, System.Globalization.DateTimeStyles.AdjustToUniversal, out dt))
                                    {
                                        @dt.AddHours(3).ToString("dd MMMM HH:mm", new System.Globalization.CultureInfo("tr-TR"))
                                    }
                                    else
                                    {
                                        @log.Timestamp
                                }
                                }
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            @if (log.Level == "Error" || log.Level == "Fatal")
                            {
                                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-red-50 text-red-700 ring-1 ring-inset ring-red-600/20">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500 me-1.5"></span> Hata
                                </span>
                            }
                            else if (log.Level == "Warning")
                            {
                                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-600/20">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500 me-1.5"></span> Uyarı
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-blue-50 text-blue-700 ring-1 ring-inset ring-blue-700/10">
                                    <span class="w-1.5 h-1.5 rounded-full bg-blue-500 me-1.5"></span> Bilgi
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-gray-800 font-medium">@log.RenderedMessage</div>
                            @if (!string.IsNullOrEmpty(log.Exception))
                            {
                                <div class="mt-2 p-3 bg-red-50/50 border border-red-100 rounded-lg text-red-600 text-xs font-mono overflow-y-auto max-h-32 shadow-inner">
                                    @log.Exception
                                </div>
                            }
                        </td>
                    </tr>
                    }
            </tbody>
        </table>
    </div>
    
    <!-- Sayfalama Alanı -->
    <div class="bg-gray-50 border-t border-gray-200 px-6 py-4 flex justify-center">
        <partial name="_Pagination" />
    </div>
</div>