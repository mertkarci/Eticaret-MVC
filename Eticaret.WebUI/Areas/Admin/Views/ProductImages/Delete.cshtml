@model Eticaret.Core.Entities.ProductImage

@{
    ViewData["Title"] = "Ürün Görselini Sil";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-admin border-danger shadow">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i> Silme İşlemini Onayla</h4>
            </div>
            <div class="card-body p-4">
                <p class="fs-5">
                    Aşağıdaki görseli kalıcı olarak silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.
                </p>
                <hr>
                <div class="text-center bg-light p-3 rounded border mb-3">
                    @if (!string.IsNullOrEmpty(Model.Name))
                    {
                        <img src="/img/products/@Model.Name" alt="@Model.Alt" class="img-fluid rounded shadow-sm" style="max-height: 200px;" />
                    }
                    <div class="mt-2 small text-muted font-monospace">@Model.Name</div>
                </div>
                <hr>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg me-2"></i> İptal</a>
                        <button type="submit" class="btn btn-danger"><i class="bi bi-trash-fill me-2"></i> Evet, Sil</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>