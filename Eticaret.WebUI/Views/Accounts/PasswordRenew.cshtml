@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="container py-4 my-md-5 d-flex flex-column justify-content-center align-items-center">

    <div class="col-12 col-md-8 col-lg-6 col-xl-5">

        <div class="card login-card border-0 shadow-sm rounded-4 bg-white">
            <div class="card-body p-4 p-sm-5">
                
                <div class="text-center mb-4">
                    <i class="bi bi-envelope-at text-primary" style="font-size: 3rem;"></i>
                    <h4 class="fw-bold mt-2">Şifremi Unuttum</h4>
                    <p class="text-muted small">E-posta adresinizi girin, size şifre sıfırlama bağlantısı gönderelim.</p>
                </div>

                @if (TempData["Message"] != null)
                {
                    @Html.Raw(TempData["Message"])
                }

                <form asp-action="PasswordRenew" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small"></div>

                    <div class="form-floating mb-4">
                        <input name="Email" type="email" class="form-control" id="Email" placeholder="name@example.com" required /> 
                        <label for="Email"><i class="bi bi-envelope me-1"></i> E-Posta Adresi</label>
                    </div>

                    <button class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm" type="submit">
                        Bağlantı Gönder <i class="bi bi-send ms-1"></i>
                    </button>
                </form>

            </div>

            <div class="card-footer bg-light border-0 text-center py-4 rounded-bottom-4">
                <span class="text-muted small">Şifrenizi hatırladınız mı?</span>
                <a asp-action="SignIn" asp-controller="Accounts" class="text-primary text-decoration-none fw-bold ms-1">
                    Giriş Yap
                </a>
            </div>
        </div>

    </div>
</div>