@model Eticaret.Core.Entities.Category

@{
    ViewData["Title"] = "Kategori Düzenle";
}

<form asp-action="Edit" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="Image" />
    <input type="hidden" asp-for="CreateDate" />

    <input type="hidden" asp-for="Slug" />

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card card-admin">
                <div class="card-header">
                    <h5 class="card-title mb-0">Kategori Bilgileri</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control form-control-lg" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="ParentId" class="form-label">Üst Kategori</label>
                            <select asp-for="ParentId" class="form-select" asp-items="ViewBag.Categories">
                                <option value="0">Ana Kategori</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="OrderNo" class="form-label"></label>
                            <input asp-for="OrderNo" class="form-control" />
                            <span asp-validation-for="OrderNo" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="card card-admin mt-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Kategori Görseli</h5>
                </div>
                <div class="card-body">
                    <label for="file-upload" class="custom-file-upload-container">
                        <div class="icon"><i class="bi bi-image"></i></div>
                        <div class="text">Görsel değiştirmek için tıklayın</div>
                        <input id="file-upload" name="Image" type="file" onchange="previewImage(event)"
                            style="display: none;" />
                    </label>
                    <div class="mt-3 text-center">
                        <img id="image-preview"
                            src="@(string.IsNullOrEmpty(Model.Image) ? "" : "/img/categories/" + Model.Image)"
                            alt="Önizleme"
                            style="max-width: 100%; max-height: 200px; border-radius: 0.5rem; display: @(string.IsNullOrEmpty(Model.Image) ? "none" : "inline-block");" />
                    </div>
                    <span asp-validation-for="Image" class="text-danger small mt-2 d-block"></span>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="sticky-form-sidebar">
                <div class="card card-admin">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Eylemler</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-submit shadow-sm btn-primary">
                                <i class="bi bi-check-circle me-2"></i> Güncelle
                            </button>
                            <a asp-action="Index" asp-area="Admin" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-2"></i> İptal
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card card-admin mt-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Durum</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check form-switch">
                            <input class="form-check-input" asp-for="isActive" />
                            <label class="form-check-label" asp-for="isActive">Aktif</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" asp-for="isTopMenu" />
                            <label class="form-check-label" asp-for="isTopMenu">Yukarıda Görünsün mü?</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function previewImage(event) {
            const reader = new FileReader();
            reader.onload = function () {
                const output = document.getElementById('image-preview');
                output.src = reader.result;
                output.style.display = 'inline-block';
            };
            reader.readAsDataURL(event.target.files[0]);
        }
    </script>
}