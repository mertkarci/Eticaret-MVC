@model Eticaret.Core.Entities.AppUser

@{
    ViewData["Title"] = "Kullanıcı Düzenle";
}

<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="UserGuid" />
    <input type="hidden" asp-for="CreateDate" />

    <div class="row g-4">
        <!-- SOL KOLON: Kullanıcı Bilgileri -->
        <div class="col-lg-8">
            <div class="card card-admin">
                <div class="card-header"><h5 class="card-title mb-0">Kullanıcı Bilgileri</h5></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Surname" class="form-label"></label>
                            <input asp-for="Surname" class="form-control" />
                            <span asp-validation-for="Surname" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" type="tel" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Username" class="form-label"></label>
                            <input asp-for="Username" class="form-control" />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" type="password" value="@Model.Password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SAĞ KOLON: Eylemler ve Durum -->
        <div class="col-lg-4">
            <div class="sticky-form-sidebar">
                <div class="card card-admin">
                    <div class="card-header"><h5 class="card-title mb-0">Eylemler</h5></div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-submit shadow-sm">
                                <i class="bi bi-check-circle me-2"></i> Güncelle
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-2"></i> İptal
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card card-admin mt-4">
                    <div class="card-header"><h5 class="card-title mb-0">Yetki ve Durum</h5></div>
                    <div class="card-body">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" asp-for="isAdmin" />
                            <label class="form-check-label" asp-for="isAdmin">Yönetici Yetkisi</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" asp-for="isActive" />
                            <label class="form-check-label" asp-for="isActive">Aktif Kullanıcı</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }