@model IEnumerable<Slider>

@{
    int index = 0; // İndikatörler için sayaç
}

<!-- Bootstrap JS motorunu kullanan ama tamamen Tailwind ile stillendirilmiş Slider -->
<div id="homeSlider" class="carousel slide relative group rounded-2xl overflow-hidden shadow-2xl" data-bs-ride="carousel">

    <!-- İndikatörler (Çizgiler) -->
    <div class="carousel-indicators absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-20 m-0 p-0">
        @for (int i = 0; i < Model.Count(); i++)
        {
            <button type="button" data-bs-target="#homeSlider" data-bs-slide-to="@i"
                class="@(i == 0 ? "active !bg-primary" : "!bg-white/50") w-8 h-1.5 rounded-full hover:!bg-white transition-all border-0" 
                aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i + 1)">
            </button>
        }
    </div>

    <div class="carousel-inner w-full h-[250px] sm:h-[350px] md:h-[450px] lg:h-[550px] bg-slate-100 dark:bg-slate-800">
        @foreach (var item in Model)
        {
            <div class="carousel-item @(item == Model.FirstOrDefault() ? "active" : "") h-full w-full">
                <a href="@item.Link" class="block w-full h-full relative group/item">
                    <img src="/img/sliders/@item.Image" class="absolute inset-0 w-full h-full object-cover object-center group-hover/item:scale-105 transition-transform duration-700" alt="@item.Title">
                    
                    <!-- Karartma (Gradient) Efekti - Yazıların okunmasını sağlar -->
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/20 to-transparent"></div>

                    <div class="absolute bottom-0 left-0 w-full p-6 md:p-12 lg:p-16 text-white text-left z-10 hidden sm:block">
                        <h5 class="text-2xl md:text-4xl lg:text-5xl font-black mb-2 md:mb-4 drop-shadow-lg tracking-tight">@item.Title</h5>
                        <p class="text-sm md:text-lg lg:text-xl font-medium opacity-90 drop-shadow max-w-3xl">@item.Description</p>
                    </div>
                </a>
            </div>
            index++;
        }
    </div>

    <!-- İleri / Geri Butonları (Sadece Hover Anında Görünür) -->
    <button class="carousel-control-prev absolute top-1/2 -translate-y-1/2 left-4 z-20 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-sm text-white hover:bg-white/40 opacity-0 group-hover:opacity-100 transition-all border-0 focus:outline-none" type="button" data-bs-target="#homeSlider" data-bs-slide="prev">
        <i class="bi bi-chevron-left text-2xl drop-shadow"></i>
    </button>
    <button class="carousel-control-next absolute top-1/2 -translate-y-1/2 right-4 z-20 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-full bg-white/20 backdrop-blur-sm text-white hover:bg-white/40 opacity-0 group-hover:opacity-100 transition-all border-0 focus:outline-none" type="button" data-bs-target="#homeSlider" data-bs-slide="next">
        <i class="bi bi-chevron-right text-2xl drop-shadow"></i>
    </button>

</div>