@model Eticaret.Core.Entities.Contact

@{
    ViewData["Title"] = "Mesaj Oku";
}

<div class="row justify-content-center">
    <div class="col-lg-9 col-xl-8">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-action="Index" asp-area="Admin" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Gelen Kutusu
            </a>
            
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger rounded-pill px-4 shadow-sm">
                <i class="bi bi-trash me-2"></i> Sil
            </a>
        </div>

        <div class="card card-admin border-0 shadow-lg rounded-4 overflow-hidden mb-5">
            
            <div class="card-header bg-white border-bottom p-4 d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 54px; height: 54px;">
                        <i class="bi bi-person-fill fs-3"></i>
                    </div>
                    <div>
                        <h5 class="mb-1 fw-bold text-dark">@Model.Name @Model.Surname</h5>
                        <a href="mailto:@Model.Email" class="text-decoration-none text-muted small">
                            <i class="bi bi-envelope me-1"></i>@Model.Email
                        </a>
                    </div>
                </div>
                <div class="text-sm-end text-muted small bg-light rounded-pill px-3 py-2 border">
                    <i class="bi bi-clock me-1"></i> @Model.CreateDate.ToString("dd MMMM yyyy, HH:mm")
                </div>
            </div>

            @if(!string.IsNullOrEmpty(Model.Phone))
            {
                <div class="bg-light px-4 py-2 border-bottom d-flex align-items-center small text-muted">
                    <i class="bi bi-telephone text-primary me-2"></i> Telefon: 
                    <a href="tel:@Model.Phone" class="text-decoration-none text-dark ms-1 fw-medium">@Model.Phone</a>
                </div>
            }

            <div class="card-body p-4 p-md-5">
                <p class="text-dark mb-0" style="line-height: 1.8; white-space: pre-wrap; font-size: 1.05rem;">@Model.Message</p>
            </div>

            <div class="card-footer bg-light border-top p-4 d-flex justify-content-end">
                <a href="mailto:@Model.Email" class="btn btn-primary rounded-pill px-5 shadow-sm py-2">
                    <i class="bi bi-reply-fill me-2 fs-5 align-middle"></i> <span class="align-middle fw-medium">E-posta ile Yanıtla</span>
                </a>
            </div>
        </div>

    </div>
</div>