@model Eticaret.Core.Entities.Product

@{
    ViewData["Title"] = "Ürün Sil";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card card-admin border-danger">
            <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0"><i class="bi bi-exclamation-triangle me-2"></i> Ürünü Silmek İstediğinize Emin Misiniz?</h5>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-4">Aşağıdaki ürün kalıcı olarak silinecektir. Bu işlem geri alınamaz.</p>
                
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted">Ürün Adı</dt>
                    <dd class="col-sm-9 fw-bold text-dark">@Model.Name</dd>

                    <dt class="col-sm-3 text-muted">Kalıcı Bağlantı</dt>
                    <dd class="col-sm-9"><code class="text-danger">/urun/@Model.Slug</code></dd>

                    <dt class="col-sm-3 text-muted">Ürün Kodu</dt>
                    <dd class="col-sm-9">@Model.ProductCode</dd>

                    <dt class="col-sm-3 text-muted">Fiyat</dt>
                    <dd class="col-sm-9 text-dark">@Model.Price.ToString("c")</dd>

                    <dt class="col-sm-3 text-muted">Stok</dt>
                    <dd class="col-sm-9">@Model.Stock Adet</dd>

                    <dt class="col-sm-3 text-muted">Kategori / Marka</dt>
                    <dd class="col-sm-9">@Model.Category?.Name / @Model.Brand?.Name</dd>
                </dl>
            </div>
            <div class="card-footer bg-light p-3">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4 shadow-sm">
                            <i class="bi bi-trash me-2"></i> Evet, Sil
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            İptal Et ve Geri Dön
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card card-admin">
            <div class="card-header"><h5 class="card-title mb-0">Silinecek Görsel</h5></div>
            <div class="card-body text-center">
                @if (!string.IsNullOrEmpty(Model.Image))
                {
                    <img src="/img/products/@Model.Image" alt="@Model.Name" class="img-fluid rounded opacity-75" style="max-height: 200px; filter: grayscale(50%);" />
                }
                else
                {
                    <div class="text-muted py-4">
                        <i class="bi bi-image fs-1 d-block mb-2"></i>
                        Görsel Yok
                    </div>
                }
            </div>
        </div>
    </div>
</div>