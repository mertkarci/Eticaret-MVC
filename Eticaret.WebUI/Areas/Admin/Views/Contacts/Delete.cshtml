@model Eticaret.Core.Entities.Contact

@{
    ViewData["Title"] = "Mesajı Sil";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        
        <div class="card card-admin border-0 shadow-sm overflow-hidden">
            <div class="card-header bg-danger bg-opacity-10 border-0 pt-4 pb-3 text-center">
                <i class="bi bi-exclamation-triangle-fill text-danger mb-2 d-block" style="font-size: 3rem;"></i>
                <h4 class="text-danger fw-bold mb-1">Bu mesajı silmek istediğinize emin misiniz?</h4>
                <p class="text-muted small mb-0">Bu işlem geri alınamaz.</p>
            </div>

            <div class="card-body p-4 bg-light">
                <div class="bg-white p-3 rounded border shadow-sm">
                    <div class="row mb-2">
                        <div class="col-4 text-muted small">Gönderen:</div>
                        <div class="col-8 fw-bold text-dark">@Model.Name @Model.Surname</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4 text-muted small">E-posta:</div>
                        <div class="col-8 text-dark">@Model.Email</div>
                    </div>
                    <div class="row">
                        <div class="col-4 text-muted small">Mesaj Özeti:</div>
                        <div class="col-8 text-secondary fst-italic text-truncate">
                            "@Model.Message"
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-footer bg-white border-top p-4 d-flex justify-content-center gap-3">
                <a asp-action="Index" asp-area="Admin" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
                    <i class="bi bi-x-lg me-1"></i> İptal
                </a>
                
                <form asp-action="Delete" method="post" class="m-0">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm">
                        <i class="bi bi-trash me-1"></i> Kalıcı Olarak Sil
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>