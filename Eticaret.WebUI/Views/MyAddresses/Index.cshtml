@model IEnumerable<Eticaret.Core.Entities.Address>
@using System.Linq

@{
    ViewData["Title"] = "Adreslerim";
}

<div class="container py-4 py-md-5">
    <div class="row">
        <!-- SOL MENÜ (SIDEBAR) -->
        <div class="col-md-4 col-lg-3 mb-4 mb-md-0">
            <partial name="_AccountSidebarPartial" />
        </div>

        <!-- SAĞ İÇERİK (ADRESLERİM KARTI) -->
        <div class="col-md-8 col-lg-9">
            <div class="card shadow-sm border-0 rounded-3">
                <!-- Kart Başlığı ve Hızlı Ekle Butonu -->
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark">Adreslerim</h5>
                    <a asp-controller="MyAddresses" asp-action="Create"
                        class="btn btn-sm btn-primary rounded-pill px-3 d-none d-md-inline-block">
                        <i class="bi bi-plus-lg me-1"></i> Yeni Adres
                    </a>
                </div>

                <!-- Kart Gövdesi -->
                <div class="card-body p-4 bg-gray-50/30">
@if (!Model.Any())
{
                        <!-- BOŞ DURUM (EMPTY STATE) -->
                        <div class="d-flex flex-column justify-content-center align-items-center text-center py-5">
                            <div class="mb-3">
                                <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center border"
                                    style="width: 80px; height: 80px;">
                                    <i class="bi bi-geo-alt text-muted fs-1"></i>
                                </div>
                            </div>
                            <h4 class="fw-bold text-dark">Henüz adres eklemediniz</h4>
                            <p class="text-muted mb-4 max-w-sm mx-auto">Siparişlerinizi daha hızlı tamamlamak için ilk
                                adresinizi hemen ekleyin.</p>
                            <a asp-controller="MyAddresses" asp-action="Create"
                                class="btn btn-primary rounded-pill px-4 py-2 shadow-sm">
                                Adres Ekle
                            </a>
                        </div>
}
else
{
                        <!-- Adresler çok uzamasın diye içten kaydırmalı (scroll) kapsayıcı -->
                        <div class="pe-2"
                            style="max-height: 650px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: #cbd5e1 transparent;">
                            <div class="row g-4 pb-2">
    @foreach (var item in Model)
    {
                                    <div class="col-md-6">
                                        <!-- ADRES KARTI -->
                                        <div
                                            class="card h-100 border-0 shadow-sm address-card position-relative bg-white rounded-3">

                                            <!-- Düzenleme Linki (Bütün karta yayılır) -->
                                            <a asp-controller="MyAddresses" asp-action="Edit" asp-route-name="@item.Title"
                                                class="stretched-link"></a>

                                            @if (item.IsActive)
                                            {
                                                <div class="position-absolute top-0 end-0 mt-3 me-3" style="z-index: 2;">
                                                    <span
                                                        class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 border border-success border-opacity-25">Aktif</span>
                                                </div>
                                            }

                                            <div class="card-body p-4 d-flex flex-column">
                                                <div class="d-flex align-items-center mb-3">
                                                    <div>
                                                        <h6 class="fw-bold text-dark mb-0">@item.Title</h6>
                                                        <small class="text-muted">@item.City / @item.District</small>
                                                    </div>
                                                </div>

                                                <div class="mb-4 flex-grow-1">
                                                    <p class="text-secondary small mb-0" style="line-height: 1.6;">
                                                        @item.OpenAddress
                                                    </p>
                                                </div>

                                                <div class="d-flex align-items-center justify-content-between pt-3 border-top border-light"
                                                    style="z-index: 2;">
                                                    <div class="d-flex gap-2">
                                                        @if (item.IsDeliveryAddress)
                                                        {
                                                            <span class="badge bg-light text-secondary border fw-normal py-2"
                                                                title="Teslimat Adresi"><i class="bi bi-truck me-1"></i>
                                                                Teslimat</span>
                                                        }
                                                        @if (item.IsBillingAddress)
                                                        {
                                                            <span class="badge bg-light text-secondary border fw-normal py-2"
                                                                title="Fatura Adresi"><i class="bi bi-receipt me-1"></i>
                                                                Fatura</span>
                                                        }
                                                    </div>
                                                    <!-- Silme Butonu -->
                                                    <a asp-controller="MyAddresses" asp-action="Delete"
                                                        asp-route-name="@item.Title"
                                                        class="btn btn-sm btn-outline-danger rounded-pill px-3 position-relative z-3">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
    }

                                <!-- YENİ ADRES EKLE KARTI (Listenin Sonu) -->
                                <div class="col-md-6">
                                    <a asp-controller="MyAddresses" asp-action="Create"
                                        class="card h-100 border-2 border-dashed border-secondary border-opacity-25 bg-transparent text-decoration-none d-flex align-items-center justify-content-center p-4 rounded-3 address-add-card transition-all hover-shadow">
                                        <div class="text-center text-muted">
                                            <div class="bg-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm"
                                                style="width: 48px; height: 48px;">
                                                <i class="bi bi-plus-lg fs-5 text-primary"></i>
                                            </div>
                                            <span class="fw-medium d-block text-dark">Yeni Adres Ekle</span>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Mobil Çıkış Yap Butonu -->
            <div class="d-md-none mt-4">
                <a href="/hesabim/cikis-yap"
                    class="btn btn-outline-danger w-100 rounded-pill shadow-sm">
                    <i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap
                </a>
            </div>
        </div>
    </div>
</div>