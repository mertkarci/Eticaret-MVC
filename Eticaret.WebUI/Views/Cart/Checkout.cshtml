@model CheckoutViewModel
@{
    ViewData["Title"] = "Satın Al";

    // Kargo Hesaplamaları
    decimal freeShippingThreshold = 1000m;
    decimal shippingCost = Model.TotalPrice >= freeShippingThreshold ? 0 : 99m;
    decimal finalTotal = Model.TotalPrice + shippingCost;
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-danger">
        @TempData["Message"]
    </div>
}
<section class="py-4 py-md-5 mb-5 mb-lg-0">
    <div class="container">

        <div class="d-flex align-items-center mb-4 mb-lg-5">
            <a class="btn btn-light rounded-circle shadow-sm me-3" title="Sepete Dön" asp-controller="Products" asp-action="Index"> <i class="bi bi-arrow-left"></i></a>
            <div>
                <h1 class="display-6 fw-bold m-0">Ödeme</h1>
                <p class="text-muted m-0 small">Siparişinizi güvenle tamamlayın.</p>
            </div>
        </div>

        @if (Model.CartProducts != null && Model.CartProducts.Any())
        {
            <form asp-controller="Cart" asp-action="Checkout" method="post" id="checkoutForm">
                <div class="row g-4 g-lg-5">

                    <div class="col-lg-8">

                        <div class="card shadow-sm border-0 mb-4 rounded-4 overflow-hidden">
                            <div class="card-header bg-white py-3 px-4 border-bottom">
                                <h5 class="mb-0 fw-bold d-flex align-items-center">
                                    <span class="badge bg-primary rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">1</span>
                                    Teslimat ve İletişim Bilgileri
                                </h5>
                            </div>
                            <div class="card-body p-4">
                                @if (User.Identity.IsAuthenticated)
                                {
                                    @if (Model.Addresses == null || !Model.Addresses.Any())
                                    {
                                        <div class="text-center py-4">
                                            <i class="bi bi-geo-alt-fill text-warning display-4 mb-3"></i>
                                            <h5 class="fw-bold">Kayıtlı Adresiniz Yok</h5>
                                            <p class="text-muted mb-4">Sipariş verebilmek için lütfen bir teslimat adresi ekleyin.</p>
                                            <a href="/adreslerim/ekle" class="btn btn-primary rounded-pill px-4">
                                                <i class="bi bi-plus-lg me-1"></i> Yeni Adres Ekle
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="row g-3">
                                            @foreach (var item in Model.Addresses)
                                            {
                                                <div class="col-md-6">
                                                    <label class="card h-100 address-card rounded-3 position-relative p-3 @(item.IsDeliveryAddress ? "selected" : "")" onclick="selectAddress(this)">
                                                        <div class="d-flex align-items-start">
                                                            <div class="form-check mt-1">
                                                                <input class="form-check-input" type="radio" name="DeliveryAddressGuid" value="@item.AddressGuid" @(item.IsDeliveryAddress ? "checked" : "") required>
                                                            </div>
                                                            <div class="ms-2">
                                                                <span class="fw-bold d-block text-dark">@item.Title</span>
                                                                <small class="text-muted d-block text-truncate" style="max-width: 200px;">@item.City / @item.District</small>
                                                                <small class="text-muted d-block text-truncate" style="max-width: 200px;">@item.OpenAddress</small>
                                                            </div>
                                                        </div>
                                                    </label>
                                                </div>
                                            }
                                        </div>

                                        <div class="mt-4 pt-3 border-top">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="sameAddress" checked onchange="toggleBillingSection()">
                                                <label class="form-check-label fw-medium user-select-none" for="sameAddress">Fatura adresim teslimat adresimle aynı olsun.</label>
                                            </div>
                                        </div>

                                        <div id="billingSection" class="mt-4" style="display: none;">
                                            <h6 class="fw-bold mb-3 text-secondary">Fatura Adresi Seçin</h6>
                                            <div class="row g-3">
                                                @foreach (var item in Model.Addresses)
                                                {
                                                    <div class="col-md-6">
                                                        <label class="card h-100 address-card rounded-3 position-relative p-3" onclick="selectBillingAddress(this)">
                                                            <div class="d-flex align-items-start">
                                                                <div class="form-check mt-1">
                                                                    <input class="form-check-input" type="radio" name="BillingAddressGuid" value="@item.AddressGuid">
                                                                </div>
                                                                <div class="ms-2">
                                                                    <span class="fw-bold d-block text-dark">@item.Title</span>
                                                                    <small class="text-muted d-block">@item.City / @item.District</small>
                                                                </div>
                                                            </div>
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                        <input type="hidden" name="BillingAddressGuid" id="billingAddressDefault" value="@Model.Addresses.FirstOrDefault(x => x.IsDeliveryAddress)?.AddressGuid">
                                    }
                                }
                                else
                                {
                                    <h6 class="fw-bold mb-3 text-secondary border-bottom pb-2"><i class="bi bi-person-lines-fill me-2"></i>İletişim Bilgileri</h6>
                                    <div class="row g-3 mb-4">
                                        <div class="col-md-6">
                                            <label class="form-label small fw-medium">Ad <span class="text-danger">*</span></label>
                                            <input type="text" name="GuestName" class="form-control" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-medium">Soyad <span class="text-danger">*</span></label>
                                            <input type="text" name="GuestSurname" class="form-control" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-medium">E-posta <span class="text-danger">*</span></label>
                                            <input type="email" name="GuestEmail" class="form-control" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-medium">Telefon <span class="text-danger">*</span></label>
                                            <input type="tel" name="GuestPhone" class="form-control" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
                                        </div>
                                    </div>

                                    <h6 class="fw-bold mb-3 text-secondary border-bottom pb-2 mt-2"><i class="bi bi-truck me-2"></i>Teslimat Adresi</h6>
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label class="form-label small fw-medium">Açık Adres <span class="text-danger">*</span></label>
                                            <textarea name="GuestOpenAddress" class="form-control" rows="3" required></textarea>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-medium">Şehir <span class="text-danger">*</span></label>
                                            <input type="text" name="GuestCity" class="form-control" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label small fw-medium">İlçe <span class="text-danger">*</span></label>
                                            <input type="text" name="GuestDistrict" class="form-control" required>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                            <div class="card-header bg-white py-3 px-4 border-bottom">
                                <h5 class="mb-0 fw-bold d-flex align-items-center">
                                    <span class="badge bg-primary rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">2</span>
                                    Fatura ve Güvenlik Bilgileri
                                </h5>
                            </div>
                            <div class="card-body p-4">
                                
                                <div class="mb-4 p-3 bg-light rounded-3 border">
                                    <label class="form-label d-block fw-bold text-dark mb-3"><i class="bi bi-receipt me-2"></i>Fatura Türü</label>
                                    <div class="form-check form-check-inline me-4">
                                        <input class="form-check-input" type="radio" name="IsCorporateInvoice" id="faturaBireysel" value="false" checked onchange="toggleInvoice()">
                                        <label class="form-check-label fw-medium user-select-none" style="cursor: pointer;" for="faturaBireysel">Bireysel Fatura</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="IsCorporateInvoice" id="faturaKurumsal" value="true" onchange="toggleInvoice()">
                                        <label class="form-check-label fw-medium user-select-none" style="cursor: pointer;" for="faturaKurumsal">Kurumsal Fatura</label>
                                    </div>
                                </div>

                                <div class="row g-4">
                                    <div class="col-12" id="alanBireysel">
                                        <label class="form-label fw-bold text-muted small">TC Kimlik Numarası <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-person-badge"></i></span>
                                            <input type="text" name="TcNo" id="inputTc" class="form-control border-start-0 ps-0 py-2" maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required>
                                        </div>
                                    </div>

                                    <div class="col-12" id="alanKurumsal" style="display: none;">
                                        <div class="row g-3">
                                            <div class="col-12">
                                                <label class="form-label fw-bold text-muted small">Firma Ünvanı <span class="text-danger">*</span></label>
                                                <input type="text" name="CompanyName" id="inputSirket" class="form-control py-2 bg-light">
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold text-muted small">Vergi Dairesi <span class="text-danger">*</span></label>
                                                <input type="text" name="TaxOffice" id="inputVd" class="form-control py-2 bg-light">
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold text-muted small">Vergi Numarası <span class="text-danger">*</span></label>
                                                <input type="text" name="TaxNumber" id="inputVno" class="form-control py-2 bg-light" maxlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="alert alert-light border mt-4 mb-0 d-flex align-items-center gap-3">
                                    <i class="bi bi-shield-check text-success fs-2"></i>
                                    <div class="small text-muted">Bir sonraki adımda <strong>İyzico Güvenli Ödeme</strong> sayfasına yönlendirileceksiniz. Ödeme bilgileriniz 256-bit SSL sertifikası ile şifrelenmektedir.</div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="col-lg-4">
                        <div class="sticky-summary">
                            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                                <div class="card-header bg-white py-3 px-4 border-bottom">
                                    <h5 class="mb-0 fw-bold">Sipariş Özeti</h5>
                                </div>
                                <div class="card-body p-0">
                                    <div style="max-height: 350px; overflow-y: auto;">
                                        <ul class="list-group list-group-flush">
                                            @foreach (var item in Model.CartProducts)
                                            {
                                                <li class="list-group-item d-flex align-items-center gap-3 py-3 px-4">
                                                    <div class="position-relative flex-shrink-0">
                                                        <img src="~/img/products/@item.Product.Image" alt="@item.Product.Name" class="rounded shadow-sm object-fit-cover" style="width: 56px; height: 56px;">
                                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary border border-white" style="font-size: 0.7rem;">@item.Quantity</span>
                                                    </div>
                                                    <div class="flex-grow-1" style="min-width: 0;">
                                                        <h6 class="mb-1 text-truncate fw-bold text-dark" style="font-size: 0.9rem;">@item.Product.Name</h6>
                                                        <small class="text-muted">Birim: @item.Product.Price.ToString("c")</small>
                                                    </div>
                                                    <div class="fw-bold text-primary">@((item.Product.Price * item.Quantity).ToString("c"))</div>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                                <div class="card-footer bg-light p-4">
                                    <div class="d-flex justify-content-between mb-2 small text-muted">
                                        <span>Ara Toplam</span>
                                        <span class="fw-medium text-dark">@Model.TotalPrice.ToString("c")</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-3 small text-muted">
                                        <span>Kargo Ücreti</span>
                                        @if (shippingCost == 0) { <span class="text-success fw-bold">Ücretsiz</span> }
                                        else { <span class="fw-medium text-dark">@shippingCost.ToString("c")</span> }
                                    </div>
                                    <hr class="text-muted opacity-25 my-3">
                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <span class="fs-5 fw-bold text-dark">Toplam Tutar</span>
                                        <span class="fs-4 fw-bold text-primary">@finalTotal.ToString("c")</span>
                                    </div>
                                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-3 fw-bold shadow-sm d-none d-lg-block">
                                        Güvenli Ödemeye Geç <i class="bi bi-chevron-right ms-1"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </form>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-cart-x text-muted opacity-25 mb-4" style="font-size: 5rem;"></i>
                <h3 class="fw-bold text-dark">Sepetiniz Boş</h3>
                <a href="/Products" class="btn btn-primary rounded-pill px-5 py-2 mt-3">Alışverişe Başla</a>
            </div>
        }
    </div>
</section>

@if (User.Identity.IsAuthenticated)
{
    <script src="~/js/checkout.js" asp-append-version="true"></script>
}

<script>
    function toggleInvoice() {
        var isCorp = document.getElementById('faturaKurumsal').checked;
        
        document.getElementById('alanBireysel').style.display = isCorp ? 'none' : 'block';
        document.getElementById('alanKurumsal').style.display = isCorp ? 'block' : 'none';
        
        document.getElementById('inputTc').required = !isCorp;
        document.getElementById('inputSirket').required = isCorp;
        document.getElementById('inputVd').required = isCorp;
        document.getElementById('inputVno').required = isCorp;

        // Geçişlerde çöp veriyi temizleme
        if(isCorp) document.getElementById('inputTc').value = '';
        else {
            document.getElementById('inputSirket').value = '';
            document.getElementById('inputVd').value = '';
            document.getElementById('inputVno').value = '';
        }
    }
</script>

<div class="fixed-bottom bg-white border-top shadow-lg p-3 d-lg-none" style="z-index: 1040;">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <small class="text-muted d-block">Toplam</small>
            <span class="fs-4 fw-bold text-primary">@finalTotal.ToString("c")</span>
        </div>
        <button type="submit" form="checkoutForm" class="btn btn-primary rounded-pill px-4 py-2 fw-bold">
            Ödemeye Geç <i class="bi bi-chevron-right ms-1"></i>
        </button>
    </div>
</div>