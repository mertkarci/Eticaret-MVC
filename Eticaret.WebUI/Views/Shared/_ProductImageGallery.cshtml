@model Eticaret.Core.Entities.Product

<style>
    .gallery-main-image {
        width: 100%;
        height: 500px;
        object-fit: contain;
        background-color: #f8f9fa;
        border-radius: 1rem;
        transition: opacity 0.3s ease-in-out;
    }

    .gallery-thumbnails-wrapper {
        position: relative;
        margin-top: 1rem;
        display: flex;
        align-items: center;
    }

    .gallery-thumbnails {
        display: flex;
        gap: 0.75rem;
        overflow-x: auto;
        scroll-behavior: smooth;
        scrollbar-width: none; /* Firefox */
        -ms-overflow-style: none; /* IE and Edge */
        padding: 0.25rem;
    }

    .gallery-thumbnails::-webkit-scrollbar {
        display: none; /* Chrome, Safari and Opera */
    }

    .gallery-thumbnail-item {
        flex: 0 0 calc(33.333% - 0.5rem); /* Tam 3 tane sığacak şekilde */
        max-width: calc(33.333% - 0.5rem);
        height: 100px;
        cursor: pointer;
        border: 2px solid transparent;
        border-radius: 0.5rem;
        overflow: hidden;
        opacity: 0.6;
        transition: all 0.2s;
    }

    .gallery-thumbnail-item.active {
        border-color: var(--main-color, #0d6efd);
        opacity: 1;
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2);
    }

    .gallery-thumbnail-item:hover {
        opacity: 1;
    }

    .gallery-thumbnail-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .scroll-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 35px;
        height: 35px;
        border-radius: 50%;
        background: white;
        border: 1px solid #dee2e6;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        color: #495057;
    }

    .scroll-btn:hover {
        background: #f8f9fa;
        color: var(--main-color, #0d6efd);
    }

    .scroll-btn.left { left: -15px; }
    .scroll-btn.right { right: -15px; }
    
    /* Eğer 3 veya daha az resim varsa butonları gizle */
    .hide-nav .scroll-btn { display: none; }
</style>

@{
    // Kapak fotoğrafı ile galeri fotoğraflarını tek bir listede birleştirelim
    var allImages = new List<string>();
    
    if (!string.IsNullOrEmpty(Model.Image))
    {
        allImages.Add(Model.Image);
    }
    
    if (Model.ProductImages != null && Model.ProductImages.Any())
    {
        allImages.AddRange(Model.ProductImages.Select(x => x.Name));
    }

    bool showNav = allImages.Count > 3;
}

<div class="product-gallery">
    <div class="position-relative">
        <span class="badge bg-danger position-absolute top-0 start-0 m-3 px-3 py-2 rounded-pill shadow"
              style="z-index: 10; font-size: 0.9rem; letter-spacing: 1px;">
            <i class="bi bi-tags-fill me-1"></i> %20 İNDİRİM
        </span>
        
        <img id="mainGalleryImage" 
             src="@(allImages.Any() ? $"/img/products/{allImages.First()}" : "/img/placeholder.png")" 
             class="gallery-main-image border border-light shadow-sm" 
             alt="@Model.Name">
    </div>

    @if (allImages.Count > 1)
    {
        <div class="gallery-thumbnails-wrapper @(showNav ? "" : "hide-nav")">
            <button class="scroll-btn left" onclick="scrollThumbnails(-1)"><i class="bi bi-chevron-left"></i></button>
            
            <div class="gallery-thumbnails" id="thumbnailContainer">
                @for (int i = 0; i < allImages.Count; i++)
                {
                    <div class="gallery-thumbnail-item @(i == 0 ? "active" : "")" 
                         onclick="changeMainImage('/img/products/@allImages[i]', this)">
                        <img src="/img/products/@allImages[i]" alt="Thumbnail @i">
                    </div>
                }
            </div>

            <button class="scroll-btn right" onclick="scrollThumbnails(1)"><i class="bi bi-chevron-right"></i></button>
        </div>
    }
</div>

<script>
    function changeMainImage(src, element) {
        // Büyük resmi değiştir
        const mainImg = document.getElementById('mainGalleryImage');
        mainImg.style.opacity = '0.5';
        
        setTimeout(() => {
            mainImg.src = src;
            mainImg.style.opacity = '1';
        }, 150);

        // Aktif sınıfını güncelle
        document.querySelectorAll('.gallery-thumbnail-item').forEach(el => {
            el.classList.remove('active');
        });
        element.classList.add('active');
    }

    function scrollThumbnails(direction) {
        const container = document.getElementById('thumbnailContainer');
        // Bir resim genişliği (yaklaşık 33%) + gap kadar kaydır
        const scrollAmount = container.clientWidth / 3; 
        container.scrollBy({ left: direction * scrollAmount, behavior: 'smooth' });
    }
</script>