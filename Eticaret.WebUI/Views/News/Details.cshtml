@model News
@{
    ViewData["Title"] = Model.Name;
}

<section class="py-8 md:py-12">
    <div class="container mx-auto px-4 max-w-4xl">

        @* --- BREADCRUMB --- *@
        <nav aria-label="breadcrumb" class="mb-6 md:mb-8">
            <ol class="flex flex-wrap items-center text-sm text-gray-500 dark:text-gray-400 gap-y-2">
                <li class="flex items-center">
                    <a asp-controller="Home" asp-action="Index" class="hover:text-primary transition-colors no-underline text-inherit flex items-center gap-1">
                        <i class="bi bi-house-door mb-0.5"></i> Ana Sayfa
                    </a>
                </li>
                <li class="flex items-center px-2"><span class="text-gray-300 dark:text-gray-600">/</span></li>
                <li class="flex items-center">
                    <a asp-controller="News" asp-action="Index" class="hover:text-primary transition-colors no-underline text-inherit">Haberler</a>
                </li>
                <li class="flex items-center px-2"><span class="text-gray-300 dark:text-gray-600">/</span></li>
                <li class="text-gray-800 dark:text-gray-200 font-medium truncate max-w-[180px] sm:max-w-xs md:max-w-md" aria-current="page" title="@Model.Name">@Model.Name</li>
            </ol>
        </nav>

        <article class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-200 dark:border-slate-700 overflow-hidden">
            
            @* Resim Alanı (Geniş Ekran) *@
            <div class="relative w-full h-[300px] md:h-[450px] bg-gray-100 dark:bg-slate-700">
                <img src="~/img/news/@Model.Image" alt="@Model.Name" class="w-full h-full object-cover" asp-append-version="true">
            </div>

            <div class="p-6 md:p-10 lg:p-12">
                
                @* Başlık ve Tarih *@
                <header class="mb-8">
                    <div class="flex items-center gap-2 text-primary font-bold text-xs mb-4 uppercase tracking-wider">
                        <i class="bi bi-megaphone-fill"></i> Duyuru / Haber
                    </div>
                    <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-gray-900 dark:text-white leading-tight mb-4">@Model.Name</h1>
                    <div class="flex items-center text-sm font-medium text-gray-500 dark:text-gray-400 pb-6 border-b border-gray-100 dark:border-slate-700">
                        <i class="bi bi-calendar3 me-2"></i> @Model.CreateDate.ToString("dd MMMM yyyy")
                    </div>
                </header>

                @* HTML İçerik Alanı *@
                <div class="prose prose-lg dark:prose-invert max-w-none text-gray-700 dark:text-gray-300 leading-relaxed space-y-4">
                    @Html.Raw(Model.Description)
                </div>

                @* Alt Kısım (Buton) *@
                <div class="mt-10 pt-8 border-t border-gray-100 dark:border-slate-700">
                    <a asp-controller="News" asp-action="Index" class="inline-flex items-center gap-2 px-6 py-3 bg-gray-100 hover:bg-primary hover:text-white dark:bg-slate-900 dark:text-gray-300 dark:hover:bg-primary dark:hover:text-white text-gray-700 font-bold rounded-lg transition-all focus:outline-none shadow-sm no-underline">
                        <i class="bi bi-arrow-left"></i> Haberlere Dön
                    </a>
                </div>
            </div>
        </article>
    </div>
</section>